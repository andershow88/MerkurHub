@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anmelden - MerkurHub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; overflow: hidden; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: linear-gradient(145deg, #0a0a14 0%, #0e0e1a 50%, #12121e 100%);
            color: #e4e6ea;
            display: flex; align-items: center; justify-content: center;
        }

        /* ── Background particles ── */
        #particleCanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

        /* ── Login Card ── */
        .login-card {
            position: relative; z-index: 10; width: 92%; max-width: 430px;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(28px) saturate(1.3);
            -webkit-backdrop-filter: blur(28px) saturate(1.3);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 28px;
            padding: clamp(1.5rem, 4vw, 2.75rem) clamp(1.25rem, 4vw, 2.5rem);
            box-shadow:
                0 8px 48px rgba(0,0,0,0.35),
                0 1px 0 rgba(255,255,255,0.08) inset,
                0 -1px 0 rgba(0,0,0,0.2) inset;
            text-align: center;
            transition: opacity 0.5s ease, transform 0.5s ease;
            animation: cardFloat 6s ease-in-out infinite;
        }
        .login-card.fade-out {
            opacity: 0;
            transform: scale(0.85) translateY(30px);
            pointer-events: none;
        }
        @@keyframes cardFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-7px); }
        }
        @@keyframes pulseRing {
            0%, 100% { transform: scale(1); opacity: 0.2; }
            50% { transform: scale(1.18); opacity: 0.45; }
        }
        @@keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        /* ── Logo area ── */
        .logo-wrapper {
            position: relative; display: inline-block; margin-bottom: 1.25rem;
        }
        .logo-ring {
            position: absolute; inset: -14px; border-radius: 50%;
            border: 2px solid #C8A96E; opacity: 0.25;
            animation: pulseRing 3s ease-in-out infinite;
        }
        .login-logo {
            width: clamp(90px, 16vw, 140px); height: auto;
            filter: drop-shadow(0 0 20px rgba(200,169,110,0.15));
        }

        /* ── Typography ── */
        .login-title {
            font-size: clamp(1.6rem, 4vw, 2.1rem); font-weight: 700;
            color: #C8A96E; margin-bottom: 0.15rem;
            letter-spacing: 0.5px;
        }
        .login-subtitle {
            font-size: clamp(0.72rem, 1.8vw, 0.88rem);
            color: rgba(255,255,255,0.4);
            margin-bottom: 1.75rem; letter-spacing: 0.3px;
        }

        /* ── Form ── */
        .form-group { margin-bottom: 1.1rem; text-align: left; }
        .form-group label {
            display: block; font-size: 0.75rem; font-weight: 600;
            color: rgba(255,255,255,0.5); margin-bottom: 0.3rem;
            text-transform: uppercase; letter-spacing: 0.4px;
        }
        .form-group input {
            width: 100%; padding: 0.72rem 1rem; font-size: 0.95rem;
            color: #e4e6ea; font-family: inherit;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px; outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .form-group input::placeholder { color: rgba(255,255,255,0.2); }
        .form-group input:focus {
            border-color: #C8A96E;
            box-shadow: 0 0 0 3px rgba(200,169,110,0.15);
        }

        /* ── Login Button ── */
        .btn-login {
            width: 100%; padding: 0.78rem; margin-top: 0.6rem;
            font-size: 1rem; font-weight: 600; font-family: inherit;
            border: none; border-radius: 12px; cursor: pointer;
            background: linear-gradient(135deg, #8B2252 0%, #6B3A5C 100%);
            color: #f0e0d0;
            letter-spacing: 0.3px;
            transition: all 0.25s;
            position: relative; overflow: hidden;
        }
        .btn-login::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
            background-size: 200% 100%;
            animation: shimmer 3s ease-in-out infinite;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 28px rgba(139,34,82,0.35);
        }
        .btn-login:active { transform: translateY(0); }
        .btn-login:disabled {
            opacity: 0.55; cursor: not-allowed; transform: none;
            box-shadow: none;
        }

        /* ── Error / Hint ── */
        .error-msg {
            margin-top: 0.85rem; font-size: 0.84rem;
            color: #e85d5d; min-height: 1.3em;
        }
        .demo-hint {
            margin-top: 1.25rem; padding-top: 0.85rem;
            border-top: 1px solid rgba(255,255,255,0.06);
            font-size: 0.73rem; color: rgba(255,255,255,0.3);
            line-height: 1.7;
        }
        .demo-hint code {
            background: rgba(255,255,255,0.07);
            padding: 0.1rem 0.38rem; border-radius: 4px;
            font-size: 0.73rem; color: #C8A96E;
        }

        /* ── Three.js Globe Container ── */
        #globeContainer {
            position: fixed; inset: 0; z-index: 50;
            opacity: 0; pointer-events: none;
            transition: opacity 0.6s ease;
        }
        #globeContainer.active { opacity: 1; }
        #globeContainer.fade-out { opacity: 0; transition: opacity 0.8s ease; }

        /* ── Welcome Overlay — Logo steigt aus München auf ── */
        .welcome-overlay {
            position: fixed; inset: 0; z-index: 100;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: transparent;
            opacity: 0; pointer-events: none;
            transition: opacity 0.5s ease;
        }
        .welcome-overlay.active { opacity: 1; pointer-events: auto; }
        .welcome-overlay.bg-fill { background: linear-gradient(145deg, #0a0a14 0%, #12121e 100%); }

        .welcome-logo {
            width: 20px; opacity: 0;
            transition: none;
        }
        .welcome-logo.ascending {
            opacity: 1;
            animation: logoAscend 2.2s cubic-bezier(0.22,1,0.36,1) forwards;
        }
        @@keyframes logoAscend {
            0%   { width: 40px; opacity: 0.8; }
            25%  { width: clamp(220px, 35vw, 400px); opacity: 1; }
            55%  { width: clamp(500px, 65vw, 800px); opacity: 0.6; }
            100% { width: 120vmax; opacity: 0.09; }
        }

        .welcome-text {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            font-size: clamp(1.2rem, 3.5vw, 2rem); font-weight: 300;
            color: #C8A96E; opacity: 0; white-space: nowrap;
            transition: opacity 0.8s ease;
        }
        .welcome-text.show { opacity: 1; }

        .welcome-sub {
            position: absolute; top: calc(50% + 2.5rem); left: 50%; transform: translateX(-50%);
            font-size: clamp(0.7rem, 1.5vw, 0.85rem);
            color: rgba(255,255,255,0.4); opacity: 0;
            transition: opacity 0.6s ease;
        }
        .welcome-sub.show { opacity: 1; }
    </style>
</head>
<body>
    <canvas id="particleCanvas"></canvas>

    <!-- Login Card -->
    <div class="login-card" id="loginCard">
        <div class="logo-wrapper">
            <div class="logo-ring"></div>
            <img src="/images/merkur-logo.svg" alt="Merkur Logo" class="login-logo" />
        </div>
        <div class="login-title">MerkurHub</div>
        <div class="login-subtitle">Merkur Privatbank KGaA</div>

        <form id="loginForm" autocomplete="on">
            <!-- Felder ausgeblendet – Auto-Login als admin -->
            <input type="hidden" id="benutzername" value="admin" />
            <input type="hidden" id="passwort" value="Admin1234!" />
            <button type="submit" class="btn-login" id="btnLogin">
                <span style="position:relative;z-index:1;">Anmelden</span>
            </button>
        </form>
        <div class="error-msg" id="errorMsg"></div>
    </div>

    <!-- Three.js Globe Container -->
    <div id="globeContainer"></div>

    <!-- Welcome Overlay -->
    <div class="welcome-overlay" id="welcomeOverlay">
        <img src="/images/merkur-logo.svg" alt="Merkur" class="welcome-logo" />
        <div class="welcome-text">Willkommen im MerkurHub</div>
        <div class="welcome-sub">Merkur Privatbank KGaA</div>
    </div>

    <script>
    /* ================================================================
       BACKGROUND PARTICLES
       ================================================================ */
    (function () {
        var c = document.getElementById('particleCanvas');
        var ctx = c.getContext('2d');
        var W, H, particles = [];

        function resize() { W = c.width = window.innerWidth; H = c.height = window.innerHeight; }
        resize();
        window.addEventListener('resize', resize);

        for (var i = 0; i < 45; i++) {
            particles.push({
                x: Math.random() * (W || 800),
                y: Math.random() * (H || 600),
                r: Math.random() * 1.8 + 0.4,
                dx: (Math.random() - 0.5) * 0.25,
                dy: (Math.random() - 0.5) * 0.25,
                o: Math.random() * 0.35 + 0.08
            });
        }

        function draw() {
            ctx.clearRect(0, 0, W, H);
            for (var i = 0; i < particles.length; i++) {
                var p = particles[i];
                p.x += p.dx; p.y += p.dy;
                if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
                if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(200,169,110,' + p.o + ')';
                ctx.fill();
            }
            requestAnimationFrame(draw);
        }
        draw();
    })();

    /* ================================================================
       LOGIN FORM (AJAX)
       ================================================================ */
    document.getElementById('loginForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        var err = document.getElementById('errorMsg');
        var btn = document.getElementById('btnLogin');
        err.textContent = '';
        btn.disabled = true;
        btn.querySelector('span').textContent = 'Wird angemeldet\u2026';

        try {
            var res = await fetch('/Account/Login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    benutzername: document.getElementById('benutzername').value.trim(),
                    passwort: document.getElementById('passwort').value
                })
            });
            var data = await res.json();

            if (data.ok) {
                // Phase 1: Fade out login card
                document.getElementById('loginCard').classList.add('fade-out');

                // Phase 2: Start globe animation after card fades
                setTimeout(function () { startGlobeAnimation(); }, 500);
            } else {
                err.textContent = data.error || 'Anmeldung fehlgeschlagen.';
                btn.disabled = false;
                btn.querySelector('span').textContent = 'Anmelden';
            }
        } catch (ex) {
            err.textContent = 'Verbindungsfehler.';
            btn.disabled = false;
            btn.querySelector('span').textContent = 'Anmelden';
        }
    });

    /* ================================================================
       THREE.JS GLOBE ANIMATION
       ================================================================ */
    function startGlobeAnimation() {
        var container = document.getElementById('globeContainer');
        container.classList.add('active');

        // Hide particle canvas
        document.getElementById('particleCanvas').style.opacity = '0';

        // ── Scene setup ──
        var scene = new THREE.Scene();
        var camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 100);
        camera.position.set(0, 2, 15);
        camera.lookAt(0, 0, 0);

        var renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);
        container.appendChild(renderer.domElement);

        // ── Helper: lat/lng to Vector3 ──
        function latLngToVector3(lat, lng, radius) {
            var phi = (90 - lat) * (Math.PI / 180);
            var theta = (lng + 180) * (Math.PI / 180);
            return new THREE.Vector3(
                -(radius * Math.sin(phi) * Math.cos(theta)),
                radius * Math.cos(phi),
                radius * Math.sin(phi) * Math.sin(theta)
            );
        }

        var GLOBE_RADIUS = 5;

        // ── Stars background ──
        var starGeo = new THREE.BufferGeometry();
        var starVerts = [];
        for (var i = 0; i < 2000; i++) {
            starVerts.push((Math.random() - 0.5) * 120, (Math.random() - 0.5) * 120, (Math.random() - 0.5) * 120);
        }
        starGeo.setAttribute('position', new THREE.Float32BufferAttribute(starVerts, 3));
        var starMat = new THREE.PointsMaterial({ color: 0xffffff, size: 0.08, transparent: true, opacity: 0.6 });
        scene.add(new THREE.Points(starGeo, starMat));

        // ── Globe sphere (dark, semi-transparent) ──
        var globeGeo = new THREE.SphereGeometry(GLOBE_RADIUS, 64, 64);
        var globeMat = new THREE.MeshBasicMaterial({ color: 0x060e1a, transparent: true, opacity: 0.92 });
        var globe = new THREE.Mesh(globeGeo, globeMat);
        scene.add(globe);

        // ── Hex grid overlay ──
        var wireGeo = new THREE.SphereGeometry(GLOBE_RADIUS * 1.002, 36, 24);
        var wireMat = new THREE.MeshBasicMaterial({ color: 0x1a4a6a, wireframe: true, transparent: true, opacity: 0.12 });
        var wireGlobe = new THREE.Mesh(wireGeo, wireMat);
        scene.add(wireGlobe);

        // ── Inner glow ──
        var innerGeo = new THREE.SphereGeometry(GLOBE_RADIUS * 0.98, 32, 32);
        var innerMat = new THREE.MeshBasicMaterial({ color: 0x0a2040, transparent: true, opacity: 0.3 });
        scene.add(new THREE.Mesh(innerGeo, innerMat));

        // ── Atmosphere multi-layer glow ──
        var atmosLayers = [
            { scale: 1.03, color: 0x1a5a8a, opacity: 0.08 },
            { scale: 1.06, color: 0x0a3a6a, opacity: 0.05 },
            { scale: 1.12, color: 0x8B2252, opacity: 0.025 }
        ];
        atmosLayers.forEach(function(a) {
            var geo = new THREE.SphereGeometry(GLOBE_RADIUS * a.scale, 32, 32);
            var mat = new THREE.MeshBasicMaterial({ color: a.color, transparent: true, opacity: a.opacity, side: THREE.BackSide });
            scene.add(new THREE.Mesh(geo, mat));
        });

        // ── Orbital rings ──
        var ringGroup = new THREE.Group();
        [0, Math.PI / 3, -Math.PI / 4].forEach(function(tilt, idx) {
            var ringGeo = new THREE.RingGeometry(GLOBE_RADIUS * 1.25, GLOBE_RADIUS * 1.26, 128);
            var ringMat = new THREE.MeshBasicMaterial({ color: idx === 0 ? 0xC8A96E : 0x4a8ab0, transparent: true, opacity: 0.12, side: THREE.DoubleSide });
            var ring = new THREE.Mesh(ringGeo, ringMat);
            ring.rotation.x = Math.PI / 2 + tilt;
            ring.rotation.z = idx * 0.5;
            ringGroup.add(ring);
        });
        scene.add(ringGroup);

        // ── Scan line (rotating band) ──
        var scanGeo = new THREE.RingGeometry(GLOBE_RADIUS * 1.001, GLOBE_RADIUS * 1.015, 64, 1, 0, Math.PI * 0.4);
        var scanMat = new THREE.MeshBasicMaterial({ color: 0x00ffaa, transparent: true, opacity: 0.15, side: THREE.DoubleSide });
        var scanLine = new THREE.Mesh(scanGeo, scanMat);
        scene.add(scanLine);

        // ── Continent outline dots ──
        var continentPoints = [];

        // Africa (rough outline)
        var africa = [
            [35.8,-5.8],[37,10.2],[33.8,11.6],[31.5,32],[30,31.2],[24.1,32.9],[20,37],
            [14.7,17.4],[12,15],[10.5,15],[7,3],[6.4,2.5],[4.3,7],[4,9.7],[0.3,9.4],
            [-1.3,9.4],[-4.8,11.8],[-6.2,12.5],[-8.8,13.3],[-11.7,17.1],[-15,12.3],
            [-17.8,12.1],[-22,14.5],[-25.8,15.2],[-28.7,16.5],[-34,18.5],[-34.8,20],
            [-33.9,25.6],[-33,27.8],[-29.8,31],[-26.3,32.9],[-19,37.8],[-12.4,40.5],
            [-6.1,39.5],[-1.4,41],[2.2,42],[4.8,36.8],[9.4,35],[10.5,34.8],[12,35],
            [11,44],[13.5,48],[20,59],[22,60],[25,50],[30,49],[35.8,39.5],[37.5,36],
            [31.6,34.3],[32.3,31.5],[29.5,32.6],[27.2,34.1],[35.8,-5.8]
        ];
        for (var i = 0; i < africa.length; i++) continentPoints.push(africa[i]);

        // Europe
        var europe = [
            [36,-5.6],[36.2,0],[38,0.5],[39.5,-0.5],[41,-0.5],[42,3.1],[43.3,3],
            [43.3,5],[44,7.5],[46.2,6.1],[47.4,7],[47.6,9.5],[48.6,8],[49,6.2],
            [50.9,3.6],[51,1.5],[51.5,1],[52,-1],[52.5,1.7],[54,8.6],[54.5,10],
            [55.7,8.4],[56,10.5],[55.5,12.7],[57.7,12],[58,11.3],[59,10.4],
            [62,5.5],[64,12],[67,15],[70,20],[71,28],[70,30],[67,26],[65,25.5],
            [61.8,24],[60.2,24.8],[59.5,28],[56,28],[54,21],[54.3,18],[52,16.5],
            [51.5,14.5],[50,14.3],[49,17],[48.6,17.5],[48,16.3],[47.5,16],[46.5,16],
            [47.3,14],[46.8,13.6],[45.5,13.5],[44.4,12.3],[43.8,12.8],[42.5,12],
            [41,17],[40.7,18],[39,20.5],[39.5,23],[40.6,23],[38.3,24],[37.8,24],
            [36,28],[37.7,23.7],[38.5,20],[39.8,19.8],[40.6,17.5],[38,15.6],
            [37.6,15.3],[39.2,9],[42.5,3.2],[41.7,-0.4],[38.7,-0.3],[36,-5.6]
        ];
        for (var i = 0; i < europe.length; i++) continentPoints.push(europe[i]);

        // Asia (rough)
        var asia = [
            [42,44],[43,51],[45,52],[50,53],[52,59],[55,61],[58,56],[60,57],
            [65,58],[68,70],[70,73],[71,78],[72,83],[73,80],[71,73],[69,68],
            [67,64],[62,70],[60,69],[55,73],[55,76],[52,79],[50,80],[48,86],
            [46,90],[48,92],[42,95],[35,98],[30,97],[25,98],[22,96.5],
            [20,93],[22,88],[24,84],[26,80],[24,79],[24,72],[26,68],[25,67],
            [27,63],[30,60],[31,48],[32,45],[35,36],[36,36],[37,39],
            [39,44],[41,43],[42,44],
            // Far east
            [45,132],[43,131],[40,128],[35,129],[33,130],[34,132],[36,137],
            [39,140],[41,140],[43,146],[45,143],[44,135],[45,132],
            // SE Asia peninsula
            [22,101],[20,100],[16,100],[14,99],[10,99],[8,100],[6,100],
            [3,101],[1,103],[1,104],[2,104],[4,104],[6,106],[10,107],
            [11,109],[16,108],[19,106],[21,106],[22,101]
        ];
        for (var i = 0; i < asia.length; i++) continentPoints.push(asia[i]);

        // North America
        var northAmerica = [
            [60,-140],[65,-168],[68,-163],[70,-155],[71,-152],[72,-127],[69,-105],
            [67,-82],[63,-78],[60,-65],[55,-60],[47,-53],[46,-60],[44,-66],
            [42,-70],[40,-74],[38,-76],[35,-76],[30,-81],[25,-80],[25.8,-82],
            [27,-83],[30,-85],[29,-89],[30,-90],[29,-93],[26,-97],[22,-97],
            [19,-96],[17,-92],[18,-88],[21,-87],[21.5,-90],[23,-90],[27,-97],
            [28,-96],[32,-107],[32,-117],[34,-119],[38,-123],[42,-124],
            [46,-124],[49,-123],[49,-127],[52,-128],[55,-131],[57,-136],
            [58,-136],[60,-140]
        ];
        for (var i = 0; i < northAmerica.length; i++) continentPoints.push(northAmerica[i]);

        // South America
        var southAmerica = [
            [12,-72],[10,-67],[8,-60],[7,-55],[5,-51],[2,-50],[-1,-48],
            [-5,-35],[-8,-35],[-12,-37],[-15,-39],[-18,-39.5],[-22,-41],
            [-23,-42],[-25,-48],[-30,-51],[-33,-53],[-38,-57],[-42,-63],
            [-46,-67],[-52,-70],[-54,-70],[-55,-68],[-53,-71],[-50,-75],
            [-46,-75],[-42,-73],[-38,-73],[-33,-72],[-27,-71],[-22,-70],
            [-18,-70],[-16,-75],[-12,-77],[-6,-81],[-2,-80],[0,-80],
            [2,-77],[5,-77],[8,-72],[10,-72],[12,-72]
        ];
        for (var i = 0; i < southAmerica.length; i++) continentPoints.push(southAmerica[i]);

        // Australia
        var australia = [
            [-12,130],[-12,136],[-14,136],[-16,136],[-17,140],[-16,146],
            [-20,149],[-23,150],[-28,153],[-33,152],[-37,150],[-39,147],
            [-38,145],[-35,137],[-34,136],[-32,134],[-32,133],[-32,132],
            [-34,130],[-34,128],[-33,127],[-32,126],[-31,115],[-25,114],
            [-22,114],[-20,119],[-15,124],[-13,130],[-12,130]
        ];
        for (var i = 0; i < australia.length; i++) continentPoints.push(australia[i]);

        // Create continent dot meshes (neon-style)
        var dotGeo = new THREE.SphereGeometry(0.025, 6, 6);
        var dotMat = new THREE.MeshBasicMaterial({ color: 0x3a9ac0, transparent: true, opacity: 0.7 });

        for (var i = 0; i < continentPoints.length; i++) {
            var pt = continentPoints[i];
            var pos = latLngToVector3(pt[0], pt[1], GLOBE_RADIUS * 1.003);
            var dot = new THREE.Mesh(dotGeo, dotMat);
            dot.position.copy(pos);
            scene.add(dot);
        }

        // Add extra density dots between outline points
        for (var i = 0; i < continentPoints.length - 1; i++) {
            var a = continentPoints[i];
            var b = continentPoints[i + 1];
            var dist = Math.sqrt(Math.pow(a[0] - b[0], 2) + Math.pow(a[1] - b[1], 2));
            var steps = Math.min(Math.floor(dist / 2.5), 4);
            for (var s = 1; s <= steps; s++) {
                var t = s / (steps + 1);
                var lat = a[0] + (b[0] - a[0]) * t;
                var lng = a[1] + (b[1] - a[1]) * t;
                var pos = latLngToVector3(lat, lng, GLOBE_RADIUS * 1.003);
                var d = new THREE.Mesh(dotGeo, dotMat);
                d.position.copy(pos);
                scene.add(d);
            }
        }

        // ── City locations ──
        var cities = [
            { name: 'Muenchen', lat: 48.14, lng: 11.58 },
            { name: 'Frankfurt', lat: 50.11, lng: 8.68 },
            { name: 'London', lat: 51.51, lng: -0.13 },
            { name: 'NewYork', lat: 40.71, lng: -74.01 },
            { name: 'Zuerich', lat: 47.37, lng: 8.54 },
            { name: 'Singapore', lat: 1.35, lng: 103.82 },
            { name: 'Tokyo', lat: 35.68, lng: 139.69 }
        ];

        // City dot meshes (brighter, larger glow)
        var cityGeo = new THREE.SphereGeometry(0.07, 16, 16);
        var cityMat = new THREE.MeshBasicMaterial({ color: 0xffd080 });
        var cityGlowGeo = new THREE.SphereGeometry(0.18, 16, 16);
        var cityGlowMat = new THREE.MeshBasicMaterial({ color: 0xC8A96E, transparent: true, opacity: 0.3 });
        var cityOuterGeo = new THREE.SphereGeometry(0.35, 12, 12);
        var cityOuterMat = new THREE.MeshBasicMaterial({ color: 0xC8A96E, transparent: true, opacity: 0.06 });

        var cityMeshes = [];
        var cityGlows = [];
        for (var i = 0; i < cities.length; i++) {
            var c = cities[i];
            var pos = latLngToVector3(c.lat, c.lng, GLOBE_RADIUS * 1.01);

            var mesh = new THREE.Mesh(cityGeo, cityMat.clone());
            mesh.position.copy(pos);
            scene.add(mesh);
            cityMeshes.push(mesh);

            var glow = new THREE.Mesh(cityGlowGeo, cityGlowMat.clone());
            glow.position.copy(pos);
            scene.add(glow);
            cityGlows.push(glow);

            var outer = new THREE.Mesh(cityOuterGeo, cityOuterMat.clone());
            outer.position.copy(pos);
            scene.add(outer);
        }

        // ── Connection lines between cities ──
        var connections = [
            [0, 1], // Muenchen - Frankfurt
            [0, 4], // Muenchen - Zuerich
            [1, 2], // Frankfurt - London
            [2, 3], // London - New York
            [0, 5], // Muenchen - Singapore
            [5, 6], // Singapore - Tokyo
            [0, 2], // Muenchen - London
            [3, 6], // New York - Tokyo
        ];

        var lineMeshes = [];
        for (var i = 0; i < connections.length; i++) {
            var conn = connections[i];
            var a = cities[conn[0]];
            var b = cities[conn[1]];
            var posA = latLngToVector3(a.lat, a.lng, GLOBE_RADIUS * 1.01);
            var posB = latLngToVector3(b.lat, b.lng, GLOBE_RADIUS * 1.01);

            // Mid point elevated above globe surface for arc
            var mid = new THREE.Vector3().addVectors(posA, posB).multiplyScalar(0.5);
            var midLen = mid.length();
            var arcHeight = posA.distanceTo(posB) * 0.3;
            mid.normalize().multiplyScalar(midLen + arcHeight);

            var curve = new THREE.QuadraticBezierCurve3(posA, mid, posB);
            var points = curve.getPoints(40);
            var lineGeo = new THREE.BufferGeometry().setFromPoints(points);
            var lineMat = new THREE.LineBasicMaterial({
                color: 0xffc860, transparent: true, opacity: 0.4
            });
            var line = new THREE.Line(lineGeo, lineMat);
            scene.add(line);
            lineMeshes.push({ line: line, curve: curve, offset: Math.random() * Math.PI * 2 });
        }

        // ── Traveling light particles (multiple per connection) ──
        var travelerGeo = new THREE.SphereGeometry(0.05, 8, 8);
        var travelers = [];
        for (var i = 0; i < lineMeshes.length; i++) {
            for (var j = 0; j < 2; j++) {
                var travelerMat = new THREE.MeshBasicMaterial({ color: 0xffdd88, transparent: true, opacity: 0.9 });
                var traveler = new THREE.Mesh(travelerGeo, travelerMat);
                scene.add(traveler);
                // Smaller trailing glow
                var trailMat = new THREE.MeshBasicMaterial({ color: 0xffc860, transparent: true, opacity: 0.3 });
                var trail = new THREE.Mesh(new THREE.SphereGeometry(0.1, 6, 6), trailMat);
                scene.add(trail);
                travelers.push({ mesh: traveler, trail: trail, curveData: lineMeshes[i], t: Math.random() });
            }
        }

        // ── Ambient + point lights ──
        scene.add(new THREE.AmbientLight(0xffffff, 0.2));
        var pointLight = new THREE.PointLight(0x4488cc, 0.5, 30);
        pointLight.position.set(5, 8, 5);
        scene.add(pointLight);

        // ── Munich target for zoom ──
        var munichPos = latLngToVector3(48.14, 11.58, GLOBE_RADIUS * 1.01);

        // ── Animation state ──
        var startTime = Date.now();
        var animating = true;
        var zoomDuration = 3000; // ms
        var holdDuration = 800;  // ms after zoom
        var fadeDuration = 800;  // ms globe fade

        // Camera start & end
        var camStart = new THREE.Vector3(0, 2, 15);
        // End: close to Munich direction
        var camEndDir = munichPos.clone().normalize();
        var camEnd = camEndDir.clone().multiplyScalar(7.5);
        camEnd.y += 0.5;

        // Globe initial rotation offset to show Europe toward camera
        // Munich at lat=48, lng=11 - rotate globe so Munich faces camera
        globe.rotation.y = -0.25;

        function animate() {
            if (!animating) return;
            requestAnimationFrame(animate);

            var elapsed = Date.now() - startTime;

            // Slow globe rotation + sync wireframe + scan line
            globe.rotation.y += 0.0008;
            wireGlobe.rotation.y = globe.rotation.y;
            ringGroup.rotation.y += 0.0004;
            ringGroup.rotation.x += 0.0001;
            scanLine.rotation.y += 0.012;
            scanLine.rotation.x = Math.sin(elapsed * 0.0005) * 0.3;

            // Pulse city glows
            for (var i = 0; i < cityGlows.length; i++) {
                var s = 1 + 0.3 * Math.sin(elapsed * 0.003 + i * 1.2);
                cityGlows[i].scale.set(s, s, s);
                cityGlows[i].material.opacity = 0.15 + 0.15 * Math.sin(elapsed * 0.003 + i);
            }

            // Animate traveling lights with trails
            for (var i = 0; i < travelers.length; i++) {
                var tr = travelers[i];
                tr.t += 0.005;
                if (tr.t > 1) tr.t -= 1;
                var pt = tr.curveData.curve.getPoint(tr.t);
                tr.mesh.position.copy(pt);
                tr.mesh.material.opacity = 0.5 + 0.5 * Math.sin(tr.t * Math.PI);
                // Trail follows slightly behind
                var trailT = (tr.t - 0.03 + 1) % 1;
                var trailPt = tr.curveData.curve.getPoint(trailT);
                tr.trail.position.copy(trailPt);
                tr.trail.material.opacity = 0.15 + 0.15 * Math.sin(tr.t * Math.PI);
            }

            // Pulse stars
            starMat.opacity = 0.5 + 0.1 * Math.sin(elapsed * 0.001);

            // Animate connection line opacity
            for (var i = 0; i < lineMeshes.length; i++) {
                lineMeshes[i].line.material.opacity = 0.2 + 0.15 * Math.sin(elapsed * 0.002 + lineMeshes[i].offset);
            }

            // Camera zoom: smooth easeInOut over zoomDuration
            if (elapsed < zoomDuration) {
                var t = elapsed / zoomDuration;
                // easeInOutCubic
                var ease = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
                camera.position.lerpVectors(camStart, camEnd, ease);
                camera.lookAt(0, 0, 0);
            }

            // After zoom: hold, then start munich pulse
            if (elapsed > zoomDuration && elapsed < zoomDuration + holdDuration) {
                // Munich bright pulse
                var munichIdx = 0;
                var pulseT = (elapsed - zoomDuration) / holdDuration;
                cityMeshes[munichIdx].scale.set(1 + pulseT, 1 + pulseT, 1 + pulseT);
                cityGlows[munichIdx].scale.set(2 + pulseT * 3, 2 + pulseT * 3, 2 + pulseT * 3);
                cityGlows[munichIdx].material.opacity = 0.4 + pulseT * 0.4;
            }

            // After hold: logo ascending from Munich point
            if (elapsed > zoomDuration + holdDuration && !container._fadingOut) {
                container._fadingOut = true;

                // Show welcome overlay on top of globe (transparent bg initially)
                var overlay = document.getElementById('welcomeOverlay');
                overlay.classList.add('active');

                // Start logo ascending animation
                var logo = overlay.querySelector('.welcome-logo');
                logo.classList.add('ascending');

                // After logo starts growing, fade the globe
                setTimeout(function () {
                    container.classList.add('fade-out');
                    overlay.classList.add('bg-fill');
                }, 600);

                // Show text when logo is big
                setTimeout(function () {
                    overlay.querySelector('.welcome-text').classList.add('show');
                    overlay.querySelector('.welcome-sub').classList.add('show');
                }, 1200);

                // Redirect — pass wasserzeichen flag so Hub shows it
                setTimeout(function () {
                    animating = false;
                    window.location.href = '/Hub/Index?splash=1';
                }, 2800);
            }

            renderer.render(scene, camera);
        }

        animate();

        // Handle resize
        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }
        window.addEventListener('resize', onResize);
    }
    </script>
</body>
</html>
