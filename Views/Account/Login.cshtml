@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anmelden - MerkurHub</title>
    <link rel="stylesheet" href="/css/merkur.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        /* ── Light / Dark mode variables ── */
        :root {
            --mc-navy:   #0b1e3e;
            --mc-gold:   #c5a04e;
            --mc-bg:     #f4f5f7;
            --mc-text:   #1e1e1e;
            --mc-card:   #ffffff;
            --mc-muted:  #6c757d;
            --mc-border: #dee2e6;
            --mc-input-bg: #f8f9fa;
            --mc-shadow: rgba(0,0,0,.08);
        }
        [data-theme="dark"] {
            --mc-bg:     #0f1520;
            --mc-text:   #e4e6ea;
            --mc-card:   #1a2236;
            --mc-muted:  #8b95a5;
            --mc-border: #2a3550;
            --mc-input-bg: #141c2e;
            --mc-shadow: rgba(0,0,0,.35);
        }

        /* ── Reset & base ── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--mc-bg);
            color: var(--mc-text);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .35s, color .35s;
            overflow: hidden;
        }

        /* ── Subtle background pattern ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 60% at 20% 30%, rgba(197,160,78,.07), transparent),
                radial-gradient(ellipse 70% 55% at 80% 70%, rgba(11,30,62,.06), transparent);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Theme toggle ── */
        .theme-toggle {
            position: fixed;
            top: 1.25rem;
            right: 1.25rem;
            z-index: 100;
            background: var(--mc-card);
            border: 1px solid var(--mc-border);
            border-radius: 50%;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            color: var(--mc-gold);
            cursor: pointer;
            box-shadow: 0 2px 10px var(--mc-shadow);
            transition: background .3s, border-color .3s, transform .2s;
        }
        .theme-toggle:hover { transform: scale(1.1); }

        /* ── Login card ── */
        .login-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 420px;
            background: var(--mc-card);
            border: 1px solid var(--mc-border);
            border-radius: 20px;
            padding: 2.75rem 2.5rem 2.25rem;
            box-shadow: 0 8px 40px var(--mc-shadow);
            text-align: center;
            transition: opacity .5s ease, transform .5s ease, background .35s, border-color .35s;
        }
        .login-card.fade-out {
            opacity: 0;
            transform: scale(.92) translateY(12px);
        }

        .login-logo {
            width: 72px;
            height: auto;
            margin-bottom: 1rem;
        }

        .login-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--mc-gold);
            letter-spacing: .5px;
            margin-bottom: .15rem;
        }

        .login-subtitle {
            font-size: .85rem;
            color: var(--mc-muted);
            margin-bottom: 2rem;
            font-weight: 400;
        }

        /* ── Form ── */
        .form-group {
            margin-bottom: 1.15rem;
            text-align: left;
        }
        .form-group label {
            display: block;
            font-size: .8rem;
            font-weight: 600;
            color: var(--mc-muted);
            margin-bottom: .35rem;
            letter-spacing: .3px;
            text-transform: uppercase;
        }
        .form-group input {
            width: 100%;
            padding: .7rem 1rem;
            font-size: .95rem;
            color: var(--mc-text);
            background: var(--mc-input-bg);
            border: 1px solid var(--mc-border);
            border-radius: 10px;
            outline: none;
            transition: border-color .25s, box-shadow .25s, background .35s, color .35s;
        }
        .form-group input:focus {
            border-color: var(--mc-gold);
            box-shadow: 0 0 0 3px rgba(197,160,78,.18);
        }

        /* ── Submit button ── */
        .btn-login {
            width: 100%;
            padding: .75rem;
            margin-top: .5rem;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: .4px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--mc-navy), #14305a);
            color: var(--mc-gold);
            cursor: pointer;
            transition: transform .2s, box-shadow .25s;
        }
        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(11,30,62,.25);
        }
        .btn-login:active { transform: translateY(0); }
        .btn-login:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

        /* ── Error ── */
        .error-msg {
            margin-top: .85rem;
            font-size: .85rem;
            color: #d9534f;
            min-height: 1.3em;
        }

        /* ── Demo hint ── */
        .demo-hint {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid var(--mc-border);
            font-size: .78rem;
            color: var(--mc-muted);
            line-height: 1.65;
            transition: border-color .35s;
        }
        .demo-hint code {
            background: var(--mc-input-bg);
            padding: .1rem .4rem;
            border-radius: 4px;
            font-size: .78rem;
            transition: background .35s;
        }

        /* ── Full-screen welcome overlay ── */
        .welcome-overlay {
            position: fixed;
            inset: 0;
            z-index: 200;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: var(--mc-navy);
            opacity: 0;
            pointer-events: none;
            transition: opacity .6s ease;
        }
        .welcome-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .welcome-logo {
            width: 0;
            height: auto;
            opacity: 0;
            transition: width .9s cubic-bezier(.22,1,.36,1), opacity .7s ease;
        }
        .welcome-overlay.active .welcome-logo {
            width: 120px;
            opacity: 1;
        }

        .welcome-text {
            margin-top: 1.75rem;
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--mc-gold);
            opacity: 0;
            transform: translateY(14px);
            transition: opacity .7s ease .55s, transform .7s ease .55s;
        }
        .welcome-overlay.active .welcome-text {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <!-- Theme toggle -->
    <button class="theme-toggle" id="themeToggle" title="Design wechseln">
        <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
    </button>

    <!-- Login card -->
    <div class="login-card" id="loginCard">
        <img src="/images/merkur-logo.svg" alt="Merkur Logo" class="login-logo" />
        <div class="login-title">MerkurHub</div>
        <div class="login-subtitle">Merkur Privatbank KGaA</div>

        <form id="loginForm" autocomplete="on">
            <div class="form-group">
                <label for="benutzername">Benutzername</label>
                <input type="text" id="benutzername" name="benutzername"
                       autocomplete="username" required autofocus />
            </div>
            <div class="form-group">
                <label for="passwort">Passwort</label>
                <input type="password" id="passwort" name="passwort"
                       autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn-login" id="btnLogin">Anmelden</button>
        </form>

        <div class="error-msg" id="errorMsg"></div>

        <div class="demo-hint">
            Demo-Zugangsdaten:<br />
            <code>admin</code> / <code>Admin1234!</code> &nbsp;&middot;&nbsp;
            <code>user</code> / <code>Demo1234!</code>
        </div>
    </div>

    <!-- Welcome overlay -->
    <div class="welcome-overlay" id="welcomeOverlay">
        <img src="/images/merkur-logo.svg" alt="Merkur Logo" class="welcome-logo" />
        <div class="welcome-text">Willkommen im MerkurHub</div>
    </div>

    <script>
        /* ── Theme toggle ── */
        (function () {
            const html  = document.documentElement;
            const icon  = document.getElementById('themeIcon');
            const saved = localStorage.getItem('merkurhub-theme');
            if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                html.setAttribute('data-theme', 'dark');
                icon.className = 'bi bi-sun-fill';
            }
            document.getElementById('themeToggle').addEventListener('click', function () {
                const isDark = html.getAttribute('data-theme') === 'dark';
                html.setAttribute('data-theme', isDark ? 'light' : 'dark');
                icon.className = isDark ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
                localStorage.setItem('merkurhub-theme', isDark ? 'light' : 'dark');
            });
        })();

        /* ── Login via AJAX ── */
        document.getElementById('loginForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            var errorMsg = document.getElementById('errorMsg');
            var btn      = document.getElementById('btnLogin');

            errorMsg.textContent = '';
            btn.disabled = true;
            btn.textContent = 'Wird angemeldet\u2026';

            try {
                var res = await fetch('/Account/Login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        benutzername: document.getElementById('benutzername').value.trim(),
                        passwort:     document.getElementById('passwort').value
                    })
                });

                var data = await res.json();

                if (data.ok) {
                    /* 1. Fade out login card */
                    document.getElementById('loginCard').classList.add('fade-out');

                    /* 2. After card fades, show welcome overlay */
                    setTimeout(function () {
                        document.getElementById('welcomeOverlay').classList.add('active');
                    }, 450);

                    /* 3. Redirect after 2.5 s */
                    setTimeout(function () {
                        window.location.href = '/Hub/Index';
                    }, 2950);
                } else {
                    errorMsg.textContent = data.error || 'Anmeldung fehlgeschlagen.';
                    btn.disabled = false;
                    btn.textContent = 'Anmelden';
                }
            } catch (_) {
                errorMsg.textContent = 'Verbindungsfehler. Bitte erneut versuchen.';
                btn.disabled = false;
                btn.textContent = 'Anmelden';
            }
        });
    </script>
</body>
</html>
