@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anmelden - MerkurHub</title>
    <link rel="stylesheet" href="/css/merkur.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --mc-navy: #0b1e3e; --mc-gold: #c5a04e; --mc-bg: #f4f5f7; --mc-text: #1e1e1e;
            --mc-card: #ffffff; --mc-muted: #6c757d; --mc-border: #dee2e6;
            --mc-input-bg: #f8f9fa; --mc-shadow: rgba(0,0,0,.08);
        }
        [data-theme="dark"] {
            --mc-bg: #0f1520; --mc-text: #e4e6ea; --mc-card: #1a2236; --mc-muted: #8b95a5;
            --mc-border: #2a3550; --mc-input-bg: #141c2e; --mc-shadow: rgba(0,0,0,.35);
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #0b1e3e 0%, #0d0d18 40%, #1a1a2e 100%);
            color: #e4e6ea;
            display: flex; align-items: center; justify-content: center;
            transition: background .35s, color .35s; overflow: hidden;
        }
        #particleCanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
        .theme-toggle {
            position: fixed; top: 1.25rem; right: 1.25rem; z-index: 100;
            background: var(--mc-card); border: 1px solid var(--mc-border); border-radius: 50%;
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            font-size: 1.15rem; color: var(--mc-gold); cursor: pointer;
            box-shadow: 0 2px 10px var(--mc-shadow); transition: all .3s;
        }
        .theme-toggle:hover { transform: scale(1.1); }

        .login-card {
            position: relative; z-index: 1; width: 92%; max-width: 440px;
            background: rgba(255,255,255,0.08); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.12); border-radius: 24px;
            padding: clamp(1.5rem, 4vw, 2.75rem) clamp(1.25rem, 4vw, 2.5rem);
            box-shadow: 0 8px 40px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.1);
            text-align: center;
            transition: opacity .5s ease, transform .5s ease;
            animation: cardFloat 6s ease-in-out infinite;
        }
        @@keyframes cardFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
        @@keyframes pulseRing { 0%,100% { transform: scale(1); opacity:.2; } 50% { transform: scale(1.15); opacity:.4; } }
        .login-card.fade-out { opacity: 0; transform: scale(.88) translateY(20px); }

        .login-logo { width: clamp(100px, 18vw, 160px); height: auto; margin-bottom: 1.25rem; }
        .login-title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: var(--mc-gold); margin-bottom: .15rem; }
        .login-subtitle { font-size: clamp(.75rem, 2vw, .9rem); color: var(--mc-muted); margin-bottom: 1.75rem; }

        .form-group { margin-bottom: 1.1rem; text-align: left; }
        .form-group label { display: block; font-size: .78rem; font-weight: 600; color: rgba(255,255,255,.5); margin-bottom: .3rem; text-transform: uppercase; letter-spacing: .3px; }
        .form-group input { width: 100%; padding: .7rem 1rem; font-size: .95rem; color: #e4e6ea; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; outline: none; transition: all .25s; }
        .form-group input:focus { border-color: var(--mc-gold); box-shadow: 0 0 0 3px rgba(197,160,78,.18); }

        .btn-login { width: 100%; padding: .75rem; margin-top: .5rem; font-size: 1rem; font-weight: 600; border: none; border-radius: 10px; background: linear-gradient(135deg, var(--mc-navy), #14305a); color: var(--mc-gold); cursor: pointer; transition: all .2s; }
        .btn-login:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(11,30,62,.25); }
        .btn-login:disabled { opacity: .6; cursor: not-allowed; transform: none; }

        .error-msg { margin-top: .85rem; font-size: .85rem; color: #d9534f; min-height: 1.3em; }
        .demo-hint { margin-top: 1.25rem; padding-top: .85rem; border-top: 1px solid rgba(255,255,255,.08); font-size: .75rem; color: rgba(255,255,255,.4); line-height: 1.65; }
        .demo-hint code { background: rgba(255,255,255,.08); padding: .1rem .35rem; border-radius: 4px; font-size: .75rem; color: var(--mc-gold); }

        /* ── Splash overlay mit Wasserzeichen-Logo ── */
        .welcome-overlay {
            position: fixed; inset: 0; z-index: 200;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: var(--mc-navy); opacity: 0; pointer-events: none; transition: opacity .6s ease;
            overflow: hidden;
        }
        .welcome-overlay.active { opacity: 1; pointer-events: auto; }

        .welcome-logo-bg {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.15);
            width: 90vmin; height: 90vmin; opacity: 0;
            transition: transform 1.6s cubic-bezier(.22,1,.36,1), opacity 1.2s ease;
        }
        .welcome-overlay.active .welcome-logo-bg {
            transform: translate(-50%, -50%) scale(1); opacity: 0.06;
        }

        .welcome-logo-front {
            position: relative; z-index: 1;
            width: clamp(80px, 15vw, 140px); opacity: 0;
            transform: scale(0.2);
            transition: transform 1.2s cubic-bezier(.22,1,.36,1) .2s, opacity .8s ease .2s;
        }
        .welcome-overlay.active .welcome-logo-front {
            transform: scale(1); opacity: 1;
        }

        .welcome-text {
            position: relative; z-index: 1;
            margin-top: 1.5rem; font-size: clamp(1.1rem, 3vw, 1.6rem); font-weight: 300;
            color: var(--mc-gold); opacity: 0; transform: translateY(18px);
            transition: opacity .7s ease .8s, transform .7s ease .8s;
        }
        .welcome-overlay.active .welcome-text { opacity: 1; transform: translateY(0); }

        .welcome-sub {
            position: relative; z-index: 1;
            margin-top: .5rem; font-size: clamp(.7rem, 1.5vw, .85rem); color: rgba(255,255,255,.4);
            opacity: 0; transition: opacity .5s ease 1.2s;
        }
        .welcome-overlay.active .welcome-sub { opacity: 1; }
    </style>
</head>
<body>
    <canvas id="particleCanvas"></canvas>
    <button class="theme-toggle" id="themeToggle" title="Design wechseln">
        <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
    </button>

    <div class="login-card" id="loginCard">
        <div style="position:relative; display:inline-block; margin-bottom:1rem;">
            <div style="position:absolute; inset:-12px; border-radius:50%; border:2px solid var(--mc-gold); opacity:.3; animation:pulseRing 3s ease-in-out infinite;"></div>
            <img src="/images/merkur-logo.svg" alt="Merkur Logo" class="login-logo" style="margin-bottom:0;" />
        </div>
        <div class="login-title">MerkurHub</div>
        <div class="login-subtitle">Merkur Privatbank KGaA</div>

        <form id="loginForm" autocomplete="on">
            <div class="form-group">
                <label for="benutzername">Benutzername</label>
                <input type="text" id="benutzername" name="benutzername" autocomplete="username" required autofocus />
            </div>
            <div class="form-group">
                <label for="passwort">Passwort</label>
                <input type="password" id="passwort" name="passwort" autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn-login" id="btnLogin">Anmelden</button>
        </form>
        <div class="error-msg" id="errorMsg"></div>
        <div class="demo-hint">
            Demo: <code>admin</code> / <code>Admin1234!</code> &middot; <code>user</code> / <code>Demo1234!</code>
        </div>
    </div>

    <div class="welcome-overlay" id="welcomeOverlay">
        <img src="/images/merkur-logo.svg" alt="" class="welcome-logo-bg" />
        <img src="/images/merkur-logo.svg" alt="Merkur" class="welcome-logo-front" />
        <div class="welcome-text">Willkommen im MerkurHub</div>
        <div class="welcome-sub">Merkur Privatbank KGaA</div>
    </div>

    <script>
        // Particles
        (function() {
            const c = document.getElementById('particleCanvas'), ctx = c.getContext('2d');
            let W, H, particles = [];
            function resize() { W = c.width = window.innerWidth; H = c.height = window.innerHeight; }
            resize(); window.addEventListener('resize', resize);
            for (let i = 0; i < 50; i++) particles.push({
                x: Math.random()*W, y: Math.random()*H, r: Math.random()*2+0.5,
                dx: (Math.random()-0.5)*0.3, dy: (Math.random()-0.5)*0.3,
                o: Math.random()*0.4+0.1
            });
            function draw() {
                ctx.clearRect(0,0,W,H);
                particles.forEach(p => {
                    p.x += p.dx; p.y += p.dy;
                    if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
                    if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
                    ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
                    ctx.fillStyle = `rgba(200,169,110,${p.o})`; ctx.fill();
                });
                requestAnimationFrame(draw);
            }
            draw();
        })();

        (function () {
            const html = document.documentElement, icon = document.getElementById('themeIcon');
            const saved = localStorage.getItem('mc-theme');
            if (saved === 'dark' || (!saved && matchMedia('(prefers-color-scheme:dark)').matches)) {
                html.setAttribute('data-theme', 'dark'); icon.className = 'bi bi-sun-fill';
            }
            document.getElementById('themeToggle').addEventListener('click', function () {
                const d = html.getAttribute('data-theme') === 'dark';
                html.setAttribute('data-theme', d ? 'light' : 'dark');
                icon.className = d ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
                localStorage.setItem('mc-theme', d ? 'light' : 'dark');
            });
        })();

        document.getElementById('loginForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const err = document.getElementById('errorMsg'), btn = document.getElementById('btnLogin');
            err.textContent = ''; btn.disabled = true; btn.textContent = 'Wird angemeldet\u2026';
            try {
                const res = await fetch('/Account/Login', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ benutzername: document.getElementById('benutzername').value.trim(), passwort: document.getElementById('passwort').value })
                });
                const data = await res.json();
                if (data.ok) {
                    document.getElementById('loginCard').classList.add('fade-out');
                    setTimeout(() => document.getElementById('welcomeOverlay').classList.add('active'), 400);
                    setTimeout(() => window.location.href = '/Hub/Index', 3200);
                } else {
                    err.textContent = data.error || 'Anmeldung fehlgeschlagen.';
                    btn.disabled = false; btn.textContent = 'Anmelden';
                }
            } catch { err.textContent = 'Verbindungsfehler.'; btn.disabled = false; btn.textContent = 'Anmelden'; }
        });
    </script>
</body>
</html>
