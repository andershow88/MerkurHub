@{
    var userName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity?.Name;
}
<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "MerkurHub")</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/merkur.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function(){var t=localStorage.getItem('mc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();
    </script>
</head>
<body>

<nav class="mc-topbar">
    <div class="mc-topbar-brand">
        <img src="~/images/merkur-logo.svg" alt="Merkur" style="height:34px;" />
        <span style="font-size:1.15rem; font-weight:700; color:var(--mc-gold);">MerkurHub</span>
    </div>

    <div class="mc-topbar-nav">
        <a href="/Hub/Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-grid-1x2-fill"></i> Hub
        </a>
    </div>

    <div class="mc-topbar-right">
        <span class="mc-topbar-user d-none-sm">
            <i class="bi bi-person-circle"></i> @userName
        </span>
        <button class="mc-theme-toggle" id="themeToggle" title="Dark/Light Mode">
            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
        </button>
        <form method="post" action="/Account/Logout" style="margin:0;">
            <button type="submit" class="mc-theme-toggle" title="Abmelden">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </form>
    </div>
</nav>

<div class="mc-main">
    @RenderBody()
</div>

<script>
    const stored = localStorage.getItem('mc-theme') || 'light';
    document.documentElement.setAttribute('data-theme', stored);
    updateThemeIcon(stored);

    document.getElementById('themeToggle')?.addEventListener('click', function () {
        const cur = document.documentElement.getAttribute('data-theme') || 'light';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateThemeIcon(next);
    });

    function updateThemeIcon(t) {
        const i = document.getElementById('themeIcon');
        if (i) i.className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }
</script>
<!-- ===== KI-Assistent FAB ===== -->
<button id="aiFab" onclick="aiOeffnen()" title="KI-Assistent"
        style="position:fixed; right:1.25rem; bottom:1.25rem; z-index:995; width:56px; height:56px; border-radius:50%; border:none; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:var(--mc-gold); box-shadow:var(--mc-shadow-lg); cursor:pointer; font-size:1.5rem; display:flex; align-items:center; justify-content:center;">
    <i class="bi bi-stars"></i>
</button>

<!-- ===== KI-Assistent Chat-Modal ===== -->
<div id="aiModal" role="dialog" aria-label="KI-Assistent"
     style="display:none; position:fixed; right:1.25rem; bottom:1.25rem; width:min(420px, calc(100vw - 2rem)); height:min(620px, calc(100vh - 2rem)); z-index:1000; background:var(--mc-surface); border:1px solid var(--mc-border); border-radius:var(--mc-radius); box-shadow:var(--mc-shadow-lg); flex-direction:column; overflow:hidden;">
    <div style="padding:.75rem 1rem; background:linear-gradient(135deg, var(--mc-navy), #2c3e64); color:#fff; display:flex; align-items:center; justify-content:space-between;">
        <div style="display:flex; align-items:center; gap:.5rem;">
            <i class="bi bi-stars" style="color:var(--mc-gold); font-size:1.25rem;"></i>
            <strong>KI-Assistent</strong>
            <span style="font-size:.75rem; opacity:.8;">MerkurHub</span>
        </div>
        <div style="display:flex; gap:.25rem;">
            <button onclick="aiVerlaufLeeren()" title="Verlauf leeren"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
            <button onclick="aiSchliessen()" title="Schließen"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>

    <div id="aiNachrichten" style="flex:1; overflow-y:auto; padding:1rem; background:var(--mc-bg); display:flex; flex-direction:column; gap:.5rem;">
        <div class="ai-msg ai-msg-assistant">
            <div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm); max-width:85%;">
                <div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>
                Hallo! Ich bin der MerkurHub KI-Assistent. Ich kann dir helfen, Informationen zu finden und Fragen zu beantworten.
            </div>
        </div>
    </div>

    <div style="padding:.75rem; border-top:1px solid var(--mc-border); background:var(--mc-surface);">
        <div style="display:flex; gap:.5rem;">
            <input type="text" id="aiInput" placeholder="Frage eingeben… (Enter zum Senden)"
                   onkeydown="aiInputKeydown(event)"
                   style="flex:1; padding:.5rem .75rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-bg); color:var(--mc-text);" />
            <button id="aiSendBtn" onclick="aiSendenAusModal()"
                    style="padding:.5rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:var(--mc-navy); color:var(--mc-gold); cursor:pointer;">
                <i class="bi bi-send"></i>
            </button>
        </div>
        <div style="font-size:.7rem; color:var(--mc-text-muted); margin-top:.35rem;">
            Antworten basieren auf verfügbaren Daten. Bitte Wichtiges verifizieren.
        </div>
    </div>
</div>

<style>
    .ai-msg-user { align-self:flex-end; max-width:85%; }
    .ai-msg-assistant { align-self:flex-start; max-width:90%; }
    .ai-msg-bubble { word-wrap:break-word; line-height:1.45; font-size:.9rem; }
    .ai-msg-user .ai-msg-bubble { background:linear-gradient(135deg, var(--mc-navy), #2c3e64) !important; color:#fff !important; border-radius:var(--mc-radius-sm); padding:.6rem .75rem; }
    .ai-msg-bubble p:last-child { margin-bottom:0; }
    .ai-msg-bubble pre { background:rgba(0,0,0,0.05); padding:.4rem; border-radius:4px; overflow-x:auto; font-size:.8rem; }
    .ai-msg-bubble code { background:rgba(0,0,0,0.06); padding:.1rem .25rem; border-radius:3px; font-size:.85em; }
    .ai-msg-bubble ul, .ai-msg-bubble ol { margin:.25rem 0 .25rem 1.25rem; padding:0; }
    .ai-msg-bubble a { color:var(--mc-primary); text-decoration:underline; }
    .ai-typing-dots { display:inline-flex; gap:3px; }
    .ai-typing-dots span { width:6px; height:6px; border-radius:50%; background:var(--mc-text-muted); animation:aiDot 1.2s infinite ease-in-out; }
    .ai-typing-dots span:nth-child(2) { animation-delay:.15s; }
    .ai-typing-dots span:nth-child(3) { animation-delay:.3s; }
    @@keyframes aiDot { 0%, 60%, 100% { opacity:.3; transform:translateY(0); } 30% { opacity:1; transform:translateY(-3px); } }
    .ai-msg-bubble button:hover { opacity:.85; }
</style>

<script>
    // ===== KI-Assistent =====
    let aiVerlauf = [];
    let aiBesetzt = false;

    function aiOeffnen() {
        const m = document.getElementById('aiModal');
        if (!m) return;
        m.style.display = 'flex';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'none';
        setTimeout(() => document.getElementById('aiInput')?.focus(), 50);
    }

    function aiSchliessen() {
        const m = document.getElementById('aiModal');
        if (m) m.style.display = 'none';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'flex';
    }

    function aiVerlaufLeeren() {
        aiVerlauf = [];
        const cont = document.getElementById('aiNachrichten');
        if (cont) cont.innerHTML = '<div class="ai-msg ai-msg-assistant"><div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>Verlauf geleert. Stelle eine neue Frage!</div></div>';
    }

    function aiInputKeydown(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            aiSendenAusModal();
        }
    }

    function aiSendenAusModal() {
        const inp = document.getElementById('aiInput');
        if (!inp) return;
        const frage = inp.value.trim();
        if (!frage || aiBesetzt) return;
        inp.value = '';
        aiSenden(frage);
    }

    async function aiSenden(frage) {
        if (aiBesetzt) return;
        aiBesetzt = true;
        const btn = document.getElementById('aiSendBtn');
        if (btn) btn.disabled = true;

        aiNachrichtAnzeigen('user', frage);
        const typingEl = aiTippenZeigen();

        try {
            const resp = await fetch('/AiAssistent/Fragen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ frage, verlauf: aiVerlauf })
            });
            const data = await resp.json();
            typingEl?.remove();

            if (data.error) {
                aiNachrichtAnzeigen('assistant', '**Fehler:** ' + data.error);
            } else {
                const antwort = data.antwort || '(leere Antwort)';
                aiNachrichtAnzeigen('assistant', antwort);
                aiVerlauf.push({ rolle: 'user', text: frage });
                aiVerlauf.push({ rolle: 'assistant', text: antwort });
                if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
            }
        } catch (err) {
            typingEl?.remove();
            aiNachrichtAnzeigen('assistant', '**Fehler:** Verbindung zum KI-Dienst fehlgeschlagen.');
        } finally {
            aiBesetzt = false;
            if (btn) btn.disabled = false;
            document.getElementById('aiInput')?.focus();
        }
    }

    function aiNachrichtAnzeigen(rolle, text) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-' + rolle;
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        if (rolle === 'assistant') {
            bubble.style.background = 'var(--mc-surface)';
            bubble.style.border = '1px solid var(--mc-border)';
            bubble.style.padding = '.75rem';
            bubble.style.borderRadius = 'var(--mc-radius-sm)';
            const label = document.createElement('div');
            label.style.cssText = 'font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;';
            label.textContent = 'KI-Assistent';
            bubble.appendChild(label);
            const body = document.createElement('div');
            body.innerHTML = aiMarkdown(text);
            bubble.appendChild(body);
        } else {
            bubble.textContent = text;
        }
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiTippenZeigen() {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return null;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        wrap.innerHTML = '<div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div class="ai-typing-dots"><span></span><span></span><span></span></div></div>';
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
        return wrap;
    }

    function aiEscapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function aiMarkdown(raw) {
        if (!raw) return '';
        let s = aiEscapeHtml(raw);
        // Code blocks
        s = s.replace(/```([\s\S]*?)```/g, (m, code) => '<pre>' + code.trim() + '</pre>');
        // Inline code
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        // Headings
        s = s.replace(/^###\s+(.+)$/gm, '<h6 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h6>');
        s = s.replace(/^##\s+(.+)$/gm, '<h5 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h5>');
        s = s.replace(/^#\s+(.+)$/gm, '<h4 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h4>');
        // Bold / Italic
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
        // Links [text](url)
        s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        // Dokument-IDs klickbar: #42
        s = s.replace(/(^|[\s(])#(\d{1,6})\b/g, '$1<a href="/Dokumente/Details/$2">#$2</a>');
        // Lists: - or *
        s = s.replace(/(^|\n)(\s*[-*]\s+.+(?:\n\s*[-*]\s+.+)*)/g, (m, p, list) => {
            const items = list.split(/\n/).map(l => l.replace(/^\s*[-*]\s+/, '').trim()).filter(x => x);
            return p + '<ul>' + items.map(i => '<li>' + i + '</li>').join('') + '</ul>';
        });
        // Paragraphs on double newline
        const parts = s.split(/\n{2,}/).map(p => {
            if (/^<(h[1-6]|ul|ol|pre|blockquote)/.test(p.trim())) return p;
            return '<p style="margin:0 0 .4rem;">' + p.replace(/\n/g, '<br/>') + '</p>';
        });
        return parts.join('');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
