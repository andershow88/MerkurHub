@{
    var userName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? User.Identity?.Name;
}
<!DOCTYPE html>
<html lang="de" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MerkurHub</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/css/merkur.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>.leaflet-tile-pane img { filter: saturate(0.85) contrast(1.05); }</style>
    <script>
        (function(){var t=localStorage.getItem('mc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();
    </script>
</head>
<body>

<nav class="mc-topbar">
    <div class="mc-topbar-brand">
        <img src="~/images/merkur-logo.svg" alt="Merkur" style="height:72px;" />
        <span style="font-size:1.15rem; font-weight:700; color:var(--mc-petrol);">MerkurHub</span>
    </div>

    <div class="mc-topbar-nav">
        <a href="/Hub/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Hub" ? "active" : "")">
            <i class="bi bi-grid-1x2-fill"></i> Hub
        </a>
        <a href="/Dokumente/Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dokumente" ? "active" : "")">
            <i class="bi bi-file-earmark-pdf"></i> Dokumentenregister
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a href="/Admin/Benutzer" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                <i class="bi bi-people"></i> Benutzer
            </a>
        }
    </div>

    <div class="mc-topbar-right">
        <span style="font-size:.825rem; color:var(--mc-text-muted); display:flex; align-items:center; gap:.35rem;">
            <i class="bi bi-clock"></i>
            <span id="deClock"></span>
            <span style="margin-left:.35rem;"><i class="bi bi-calendar3"></i></span>
            <span id="deDate"></span>
        </span>
        <button onclick="ragFensterOeffnen()" style="padding:.4rem .85rem; border:2px solid var(--mc-petrol); border-radius:var(--mc-radius-pill); background:transparent; color:var(--mc-petrol); cursor:pointer; font-size:.8rem; font-weight:500; font-family:'Roboto',sans-serif; display:flex; align-items:center; gap:.4rem; transition:all .2s;" title="Wissenssuche" onmouseover="this.style.background='var(--mc-petrol)';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='var(--mc-petrol)'"
            <i class="bi bi-book"></i> Wissenssuche
        </button>
        <span class="mc-topbar-user d-none-sm">
            <i class="bi bi-person-circle"></i> @userName
        </span>
        <button class="mc-theme-toggle" id="themeToggle" title="Dark/Light Mode">
            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
        </button>
        <form method="post" action="/Account/Logout" style="margin:0;">
            <button type="submit" class="mc-theme-toggle" title="Abmelden">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </form>
    </div>
</nav>

<!-- Wasserzeichen Logo -->
<div id="wasserzeichen" style="position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); z-index:0; pointer-events:none; opacity:0; transition:opacity 1s ease;">
    <img src="/images/merkur-logo.svg" alt="" style="width:120vmax; opacity:0.07;" />
</div>

<div class="mc-main" style="position:relative; z-index:1;">
    @RenderBody()
</div>

<script>
    const stored = localStorage.getItem('mc-theme') || 'light';
    document.documentElement.setAttribute('data-theme', stored);
    updateThemeIcon(stored);

    document.getElementById('themeToggle')?.addEventListener('click', function () {
        const cur = document.documentElement.getAttribute('data-theme') || 'light';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('mc-theme', next);
        updateThemeIcon(next);
    });

    function updateThemeIcon(t) {
        const i = document.getElementById('themeIcon');
        if (i) i.className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
    }

    // Wasserzeichen einblenden (nach Login oder immer)
    (function() {
        var wz = document.getElementById('wasserzeichen');
        if (!wz) return;
        var fromSplash = new URLSearchParams(window.location.search).get('splash');
        if (fromSplash) {
            // Direkt sichtbar nach Login-Animation
            wz.style.opacity = '1';
            // URL bereinigen (splash Parameter entfernen)
            history.replaceState(null, '', window.location.pathname);
        } else {
            // Immer leicht sichtbar
            wz.style.opacity = '1';
        }
    })();

    // Deutsche Zeit (Europe/Berlin)
    function updateDeClock() {
        const now = new Date();
        const opts = { timeZone: 'Europe/Berlin' };
        document.getElementById('deClock').textContent = now.toLocaleTimeString('de-DE', { ...opts, hour: '2-digit', minute: '2-digit' });
        document.getElementById('deDate').textContent = now.toLocaleDateString('de-DE', { ...opts, day: '2-digit', month: '2-digit', year: 'numeric' });
    }
    updateDeClock();
    setInterval(updateDeClock, 30000);
</script>
<!-- ===== RAG Wissenssuche Fenster ===== -->
<div id="ragFenster" style="display:none; position:fixed; z-index:1001; top:10vh; left:calc(50vw - 300px); width:min(620px,calc(100vw - 2rem)); height:min(700px,calc(100vh - 4rem)); background:#fff; border:1px solid #ddd; border-radius:var(--mc-radius); box-shadow:0 8px 40px rgba(0,0,0,.25); flex-direction:column; overflow:hidden; resize:both; min-width:360px; min-height:400px;">
    <div id="ragHeader" style="padding:.65rem 1rem; background:var(--mc-petrol); color:#fff; display:flex; align-items:center; justify-content:space-between; cursor:move; user-select:none; flex-shrink:0;">
        <div style="display:flex; align-items:center; gap:.5rem;">
            <i class="bi bi-book" style="color:var(--mc-gold); font-size:1.15rem;"></i>
            <strong>Wissenssuche</strong>
            <span style="font-size:.72rem; opacity:.7;">Dokumente durchsuchen</span>
        </div>
        <div style="display:flex; gap:.25rem;">
            <button onclick="ragPopout()" title="In eigenem Fenster &ouml;ffnen" style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .4rem; font-size:.9rem;"><i class="bi bi-box-arrow-up-right"></i></button>
            <button onclick="ragMaximieren()" title="Maximieren" style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .4rem; font-size:.9rem;"><i class="bi bi-arrows-fullscreen" id="ragMaxIcon"></i></button>
            <button onclick="ragFensterSchliessen()" title="Schlie&szlig;en" style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .4rem; font-size:.9rem;"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>

    <!-- Auswahl-Screen -->
    <div id="ragAuswahl" style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:2rem;">
        <div style="font-size:1.1rem; font-weight:600; color:var(--mc-text); margin-bottom:.5rem;">Was möchtest du tun?</div>
        <button onclick="ragSucheModus()" style="width:100%; max-width:360px; padding:1.25rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius); background:var(--mc-bg); cursor:pointer; text-align:left; display:flex; align-items:center; gap:1rem; transition:all .2s;" onmouseover="this.style.borderColor='var(--mc-gold)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--mc-border)';this.style.transform=''">
            <div style="width:48px; height:48px; border-radius:12px; background:var(--mc-petrol); display:flex; align-items:center; justify-content:center;"><i class="bi bi-search" style="color:#fff; font-size:1.3rem;"></i></div>
            <div><div style="font-weight:600; color:var(--mc-text);">Inhalte durchsuchen</div><div style="font-size:.8rem; color:var(--mc-text-muted);">Stelle Fragen zu allen hochgeladenen Dokumenten</div></div>
        </button>
        <button onclick="aiOeffnen(); ragFensterSchliessen();" style="width:100%; max-width:360px; padding:1.25rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius); background:var(--mc-bg); cursor:pointer; text-align:left; display:flex; align-items:center; gap:1rem; transition:all .2s;" onmouseover="this.style.borderColor='var(--mc-gold)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--mc-border)';this.style.transform=''">
            <div style="width:48px; height:48px; border-radius:12px; background:var(--mc-gold); display:flex; align-items:center; justify-content:center;"><i class="bi bi-stars" style="color:#fff; font-size:1.3rem;"></i></div>
            <div><div style="font-weight:600; color:var(--mc-text);">KI-Assistent</div><div style="font-size:.8rem; color:var(--mc-text-muted);">Allgemeine Fragen &amp; Bankwissen</div></div>
        </button>
    </div>

    <!-- Such-Modus -->
    <div id="ragSuche" style="display:none; flex:1; flex-direction:column; overflow:hidden;">
        <div style="padding:.5rem 1rem; border-bottom:1px solid var(--mc-border); display:flex; align-items:center; gap:.5rem;">
            <button onclick="ragZurueck()" style="background:none; border:none; cursor:pointer; color:var(--mc-text-muted); font-size:.9rem;"><i class="bi bi-arrow-left"></i></button>
            <span style="font-size:.85rem; font-weight:500;">Inhalte durchsuchen</span>
            <span id="ragDokCount" style="margin-left:auto; font-size:.72rem; color:var(--mc-text-muted);"></span>
        </div>
        <div id="ragNachrichten" style="flex:1; overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:.5rem;">
            <div class="ai-msg ai-msg-assistant">
                <div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);">
                    <div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">Dokumenten-Assistent</div>
                    Stelle eine Frage zu den hochgeladenen Dokumenten. Ich durchsuche alle Inhalte und zeige dir die relevanten Stellen mit Quellenangabe.
                </div>
            </div>
        </div>
        <div style="padding:.65rem 1rem; border-top:1px solid var(--mc-border); flex-shrink:0;">
            <div style="display:flex; gap:.5rem;">
                <input type="text" id="ragInput" placeholder="Frage zu Dokumenten eingeben…" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();ragSenden();}" style="flex:1; padding:.55rem .75rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-bg); color:var(--mc-text); font-size:.9rem;" />
                <button id="ragSendBtn" onclick="ragSenden()" style="padding:.55rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:var(--mc-petrol); color:#fff; cursor:pointer;"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>
</div>

<script>
// ===== RAG Wissenssuche =====
let ragVerlauf = [], ragBesetzt = false, ragMaximiert = false;
let ragDragOffset = {x:0, y:0}, ragDragging = false;

function ragFensterOeffnen() {
    const f = document.getElementById('ragFenster');
    f.style.display = 'flex';
    document.getElementById('ragAuswahl').style.display = 'flex';
    document.getElementById('ragSuche').style.display = 'none';
}
function ragFensterSchliessen() { document.getElementById('ragFenster').style.display = 'none'; }

function ragMaximieren() {
    const f = document.getElementById('ragFenster');
    ragMaximiert = !ragMaximiert;
    if (ragMaximiert) {
        f.dataset.prevStyle = f.style.cssText;
        f.style.cssText = 'display:flex; position:fixed; z-index:1001; inset:0; width:100%; height:100%; border-radius:0; flex-direction:column; overflow:hidden; background:var(--mc-surface); border:none;';
        document.getElementById('ragMaxIcon').className = 'bi bi-fullscreen-exit';
    } else {
        f.style.cssText = f.dataset.prevStyle || '';
        f.style.display = 'flex';
        document.getElementById('ragMaxIcon').className = 'bi bi-arrows-fullscreen';
    }
}

function ragPopout() {
    var w = window.open('', 'MerkurHub_Wissen', 'width=620,height=720,resizable=yes,scrollbars=no');
    if (!w) { alert('Popup wurde blockiert. Bitte erlauben Sie Popups f\u00fcr diese Seite.'); return; }
    var theme = document.documentElement.getAttribute('data-theme') || 'light';
    var petrol = theme === 'dark' ? '#5aabb5' : '#00515A';
    var gold = theme === 'dark' ? '#d4b47a' : '#C8A96E';
    var bg = theme === 'dark' ? '#111118' : '#f3f5f8';
    var surface = theme === 'dark' ? '#1c1c26' : '#ffffff';
    var border = theme === 'dark' ? '#2c2c3a' : '#e4e7eb';
    var text = theme === 'dark' ? '#d0d0dc' : '#4a5568';
    var textDark = theme === 'dark' ? '#e8e8f0' : '#1a202c';
    var textMuted = theme === 'dark' ? '#7a7a8a' : '#8895a7';
    var verlaufJson = JSON.stringify(ragVerlauf);
    w.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>Wissenssuche \u2013 MerkurHub</title>'
        + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">'
        + '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">'
        + '<style>'
        + '*{box-sizing:border-box;margin:0;padding:0}'
        + 'body{font-family:Inter,system-ui,sans-serif;background:'+bg+';color:'+text+';height:100vh;display:flex;flex-direction:column;}'
        + '.header{padding:.75rem 1rem;background:'+petrol+';color:#fff;display:flex;align-items:center;gap:.5rem;}'
        + '.header i.star{color:'+gold+';font-size:1.15rem}'
        + '.chat{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.5rem;}'
        + '.msg-user{align-self:flex-end;max-width:85%}'
        + '.msg-ast{align-self:flex-start;max-width:90%}'
        + '.bubble{word-wrap:break-word;line-height:1.5;font-size:.9rem;padding:.65rem .8rem;border-radius:10px;}'
        + '.msg-user .bubble{background:'+petrol+';color:#fff;}'
        + '.msg-ast .bubble{background:'+surface+';border:1px solid '+border+';color:'+text+';}'
        + '.bubble strong{color:'+textDark+'}'
        + '.bubble p:last-child{margin-bottom:0}'
        + '.bubble ul,.bubble ol{margin:.25rem 0 .25rem 1.25rem;padding:0}'
        + '.bubble pre{background:rgba(0,0,0,.05);padding:.4rem;border-radius:4px;font-size:.8rem;white-space:pre-wrap}'
        + '.bubble code{background:rgba(0,0,0,.06);padding:.1rem .25rem;border-radius:3px;font-size:.85em}'
        + '.bubble a{color:'+petrol+';text-decoration:underline}'
        + '.label{font-size:.7rem;color:'+textMuted+';margin-bottom:.2rem;}'
        + '.bar{padding:.75rem;border-top:1px solid '+border+';background:'+surface+';display:flex;gap:.5rem;}'
        + '.bar input{flex:1;padding:.5rem .75rem;border:1px solid '+border+';border-radius:8px;background:'+bg+';color:'+text+';font-size:.9rem;outline:none;font-family:inherit;}'
        + '.bar input:focus{border-color:'+petrol+'}'
        + '.bar button{padding:.5rem 1rem;border:none;border-radius:8px;background:'+petrol+';color:#fff;cursor:pointer;font-size:1rem;}'
        + '.spin{width:18px;height:18px;border:2px solid '+border+';border-top-color:'+petrol+';border-radius:50%;animation:s .7s linear infinite;display:inline-block}'
        + '@@keyframes s{to{transform:rotate(360deg)}}'
        + '</style></head><body>'
        + '<div class="header"><i class="bi bi-book star"></i><strong>Wissenssuche</strong><span style="font-size:.75rem;opacity:.8;">Dokumente durchsuchen</span></div>'
        + '<div class="chat" id="chat"></div>'
        + '<div class="bar"><input id="inp" placeholder="Frage zu Dokumenten eingeben\u2026" autofocus /><button onclick="senden()"><i class="bi bi-send"></i></button></div>'
        + '<script>'
        + 'var verlauf='+verlaufJson+';'
        + 'var besetzt=false;'
        + 'var parentOrigin='+JSON.stringify(window.location.origin)+';'
        + 'document.getElementById("inp").addEventListener("keydown",function(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();senden();}});'
        + 'function md(r){if(!r)return"";var s=r.replace(/&/g,"\\&amp;").replace(/</g,"\\&lt;").replace(/>/g,"\\&gt;");'
        + 's=s.replace(/```(\\w*)\\n?([\\s\\S]*?)```/g,function(m,l,c){return"<pre>"+c.trim()+"</pre>";});'
        + 's=s.replace(/`([^`]+)`/g,"<code>$1</code>");'
        + 's=s.replace(/\\*\\*([^*]+)\\*\\*/g,"<strong>$1</strong>");'
        + 's=s.replace(/(^|[^*])\\*([^*\\n]+)\\*/g,"$1<em>$2</em>");'
        + 's=s.replace(/^###\\s+(.+)$/gm,"<h5 style=\\"font-weight:600;margin:.5rem 0 .25rem\\">$1</h5>");'
        + 's=s.replace(/^##\\s+(.+)$/gm,"<h4 style=\\"font-weight:600;margin:.6rem 0 .3rem\\">$1</h4>");'
        + 's=s.replace(/(^|\\n)((?:\\d+\\.\\s+.+(?:\\n|$))+)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\d+\\.\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ol>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ol>";});'
        + 's=s.replace(/(^|\\n)(\\s*[-*]\\s+.+(?:\\n\\s*[-*]\\s+.+)*)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\s*[-*]\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ul>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ul>";});'
        + 'return s.split(/\\n{2,}/).map(function(p){p=p.trim();if(!p||/^<(h[1-6]|ul|ol|pre|table|hr)/.test(p))return p;return"<p style=\\"margin:0 0 .4rem\\">"+p.replace(/\\n/g,"<br/>")+"</p>";}).join("");'
        + '}'
        + 'function msg(rolle,text){var c=document.getElementById("chat");var w=document.createElement("div");w.className=rolle==="user"?"msg-user":"msg-ast";var b=document.createElement("div");b.className="bubble";'
        + 'if(rolle==="assistant"){b.innerHTML="<div class=\\"label\\">Dokumenten-Assistent</div>"+md(text);}else{b.textContent=text;}'
        + 'w.appendChild(b);c.appendChild(w);c.scrollTop=c.scrollHeight;}'
        + 'if(verlauf.length){verlauf.forEach(function(v){msg(v.rolle==="assistant"?"assistant":"user",v.text);});}else{msg("assistant","Stelle eine Frage zu den hochgeladenen Dokumenten. Ich durchsuche alle Inhalte und zeige dir die relevanten Stellen.");}'
        + 'async function senden(){var inp=document.getElementById("inp");var frage=inp.value.trim();if(!frage||besetzt)return;besetzt=true;inp.value="";msg("user",frage);'
        + 'var c=document.getElementById("chat");var t=document.createElement("div");t.className="msg-ast";t.innerHTML="<div class=\\"bubble\\"><div class=\\"spin\\"></div> Dokumente werden durchsucht\\u2026</div>";c.appendChild(t);c.scrollTop=c.scrollHeight;'
        + 'try{var r=await fetch(parentOrigin+"/DokumentSucheApi/Fragen",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({frage:frage,verlauf:verlauf}),credentials:"include"});'
        + 'var d=await r.json();t.remove();if(d.error){msg("assistant","**Fehler:** "+d.error);}else{var a=d.antwort||"(leer)";if(d.quellen&&d.quellen.length){a+="\\n\\n---\\n**Quellen:**\\n";d.quellen.forEach(function(q){a+="- "+q.dokument+", Seite "+q.seite+" ("+q.relevanz+"% Relevanz)\\n";});}'
        + 'msg("assistant",a);verlauf.push({rolle:"user",text:frage});verlauf.push({rolle:"assistant",text:d.antwort||""});if(verlauf.length>8)verlauf=verlauf.slice(-8);}'
        + '}catch(e){t.remove();msg("assistant","**Fehler:** Verbindung fehlgeschlagen.");}finally{besetzt=false;inp.focus();}}'
        + '<\/script></body></html>');
    w.document.close();
    ragFensterSchliessen();
}

function ragSucheModus() {
    document.getElementById('ragAuswahl').style.display = 'none';
    document.getElementById('ragSuche').style.display = 'flex';
    setTimeout(() => document.getElementById('ragInput')?.focus(), 50);
    fetch('/api/Tiles').catch(()=>{});
}

function ragZurueck() {
    document.getElementById('ragSuche').style.display = 'none';
    document.getElementById('ragAuswahl').style.display = 'flex';
}

async function ragSenden() {
    const inp = document.getElementById('ragInput');
    const frage = inp?.value.trim();
    if (!frage || ragBesetzt) return;
    ragBesetzt = true;
    inp.value = '';
    const btn = document.getElementById('ragSendBtn');
    if (btn) btn.disabled = true;

    ragMsgAnzeigen('user', frage);
    const typEl = ragTippenZeigen();

    try {
        const resp = await fetch('/DokumentSucheApi/Fragen', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ frage, verlauf: ragVerlauf })
        });
        const data = await resp.json();
        typEl?.remove();

        if (data.error) {
            ragMsgAnzeigen('assistant', '**Fehler:** ' + data.error);
        } else {
            let html = data.antwort || '';
            if (data.quellen?.length) {
                html += '\n\n---\n**Quellen:**\n';
                data.quellen.forEach(q => {
                    html += `- [${q.dokument}, Seite ${q.seite}](/Dokumente/Herunterladen/${q.dokumentId}) _(${q.relevanz}% Relevanz)_\n`;
                });
            }
            ragMsgAnzeigen('assistant', html);
            ragVerlauf.push({rolle:'user', text:frage});
            ragVerlauf.push({rolle:'assistant', text: data.antwort || ''});
            if (ragVerlauf.length > 8) ragVerlauf = ragVerlauf.slice(-8);
        }
    } catch { typEl?.remove(); ragMsgAnzeigen('assistant', '**Fehler:** Verbindung fehlgeschlagen.'); }
    finally { ragBesetzt = false; if (btn) btn.disabled = false; inp?.focus(); }
}

function ragMsgAnzeigen(rolle, text) {
    const cont = document.getElementById('ragNachrichten');
    if (!cont) return;
    const wrap = document.createElement('div');
    wrap.className = 'ai-msg ai-msg-' + rolle;
    const bubble = document.createElement('div');
    bubble.className = 'ai-msg-bubble';
    if (rolle === 'assistant') {
        bubble.style.cssText = 'background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);';
        bubble.innerHTML = '<div style="font-size:.75rem;color:var(--mc-text-muted);margin-bottom:.25rem;">Dokumenten-Assistent</div>' + aiMarkdown(text);
    } else { bubble.textContent = text; }
    wrap.appendChild(bubble);
    cont.appendChild(wrap);
    cont.scrollTop = cont.scrollHeight;
}

function ragTippenZeigen() {
    const cont = document.getElementById('ragNachrichten');
    if (!cont) return null;
    const w = document.createElement('div');
    w.className = 'ai-msg ai-msg-assistant';
    w.innerHTML = '<div class="ai-msg-bubble" style="background:var(--mc-surface);border:1px solid var(--mc-border);padding:.75rem;border-radius:var(--mc-radius-sm);"><div style="display:flex;align-items:center;gap:.75rem;"><div class="search-spinner" style="width:20px;height:20px;border-width:2px;"></div><span style="font-size:.85rem;color:var(--mc-text-muted);">Dokumente werden durchsucht...</span></div></div>';
    cont.appendChild(w);
    cont.scrollTop = cont.scrollHeight;
    return w;
}

// Drag
const ragH = document.getElementById('ragHeader');
if (ragH) {
    ragH.addEventListener('mousedown', function(e) {
        if (ragMaximiert) return;
        const f = document.getElementById('ragFenster');
        ragDragging = true;
        ragDragOffset.x = e.clientX - f.offsetLeft;
        ragDragOffset.y = e.clientY - f.offsetTop;
    });
    document.addEventListener('mousemove', function(e) {
        if (!ragDragging) return;
        const f = document.getElementById('ragFenster');
        f.style.left = (e.clientX - ragDragOffset.x) + 'px';
        f.style.top = (e.clientY - ragDragOffset.y) + 'px';
    });
    document.addEventListener('mouseup', function() { ragDragging = false; });
}
</script>

<style>
#ragFenster .search-spinner{border:3px solid var(--mc-border);border-top-color:var(--mc-gold);border-radius:50%;animation:ragSpin .8s linear infinite;}
@@keyframes ragSpin{to{transform:rotate(360deg);}}
[data-theme="dark"] #ragFenster{background:#1e1e2e !important; border-color:#3a3a50 !important;}
[data-theme="dark"] #aiModal{background:#1e1e2e !important; border-color:#3a3a50 !important;}
</style>

<!-- ===== KI-Assistent FAB ===== -->
<button id="aiFab" onclick="aiOeffnen()" title="KI-Assistent"
        style="position:fixed; right:1.25rem; bottom:1.25rem; z-index:995; width:56px; height:56px; border-radius:50%; border:none; background:var(--mc-petrol); color:#fff; box-shadow:var(--mc-shadow-lg); cursor:pointer; font-size:1.5rem; display:flex; align-items:center; justify-content:center;">
    <i class="bi bi-stars"></i>
</button>

<!-- ===== KI-Assistent Chat-Modal ===== -->
<div id="aiModal" role="dialog" aria-label="KI-Assistent"
     style="display:none; position:fixed; right:1.25rem; bottom:1.25rem; width:min(500px, calc(100vw - 2rem)); height:min(70vh, calc(100vh - 2rem)); min-width:320px; min-height:350px; z-index:1000; background:var(--mc-surface,#fff); border:1px solid var(--mc-border,#ddd); border-radius:var(--mc-radius); box-shadow:0 8px 32px rgba(0,0,0,.2); flex-direction:column; overflow:hidden; resize:both;">
    <div id="aiHeader" style="padding:.75rem 1rem; background:linear-gradient(135deg, var(--mc-petrol,#00515A), #2c3e64); color:#fff; display:flex; align-items:center; justify-content:space-between; cursor:move; user-select:none;">
        <div style="display:flex; align-items:center; gap:.5rem;">
            <i class="bi bi-stars" style="color:var(--mc-gold); font-size:1.15rem;"></i>
            <strong>KI-Assistent</strong>
            <span style="font-size:.75rem; opacity:.8;">MerkurHub</span>
        </div>
        <div style="display:flex; gap:.25rem;">
            <button onclick="aiPopout()" title="In eigenem Fenster &ouml;ffnen"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-box-arrow-up-right"></i>
            </button>
            <button onclick="aiMaximieren()" title="Maximieren/Verkleinern"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-arrows-fullscreen" id="aiMaxIcon"></i>
            </button>
            <button onclick="aiVerlaufLeeren()" title="Verlauf leeren"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
            <button onclick="aiSchliessen()" title="Schlie&szlig;en"
                    style="background:transparent; border:none; color:#fff; cursor:pointer; padding:.25rem .5rem;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    </div>

    <div id="aiNachrichten" style="flex:1; overflow-y:auto; padding:1rem; background:var(--mc-bg); display:flex; flex-direction:column; gap:.5rem;">
        <div class="ai-msg ai-msg-assistant">
            <div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm); max-width:85%;">
                <div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>
                Hallo! Ich bin der MerkurHub KI-Assistent. Ich kann dir helfen, Informationen zu finden und Fragen zu beantworten.
            </div>
        </div>
    </div>

    <div style="padding:.75rem; border-top:1px solid var(--mc-border); background:var(--mc-surface);">
        <div style="display:flex; gap:.5rem;">
            <input type="text" id="aiInput" placeholder="Frage eingeben… (Enter zum Senden)"
                   onkeydown="aiInputKeydown(event)"
                   style="flex:1; padding:.5rem .75rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm); background:var(--mc-bg); color:var(--mc-text);" />
            <button id="aiSendBtn" onclick="aiSendenAusModal()"
                    style="padding:.5rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:var(--mc-petrol); color:#fff; cursor:pointer;">
                <i class="bi bi-send"></i>
            </button>
        </div>
        <div style="font-size:.7rem; color:var(--mc-text-muted); margin-top:.35rem;">
            Antworten basieren auf verfügbaren Daten. Bitte Wichtiges verifizieren.
        </div>
    </div>
</div>

<style>
    .ai-msg-user { align-self:flex-end; max-width:85%; }
    .ai-msg-assistant { align-self:flex-start; max-width:90%; }
    .ai-msg-bubble { word-wrap:break-word; line-height:1.45; font-size:.9rem; }
    .ai-msg-user .ai-msg-bubble { background:var(--mc-petrol) !important; color:#fff !important; border-radius:var(--mc-radius-sm); padding:.6rem .75rem; }
    .ai-msg-bubble p:last-child { margin-bottom:0; }
    .ai-msg-bubble pre { background:rgba(0,0,0,0.05); padding:.4rem; border-radius:4px; overflow-x:auto; font-size:.8rem; }
    .ai-msg-bubble code { background:rgba(0,0,0,0.06); padding:.1rem .25rem; border-radius:3px; font-size:.85em; }
    .ai-msg-bubble ul, .ai-msg-bubble ol { margin:.25rem 0 .25rem 1.25rem; padding:0; }
    .ai-msg-bubble a { color:var(--mc-primary); text-decoration:underline; }
    .ai-typing-dots { display:inline-flex; gap:3px; }
    .ai-typing-dots span { width:6px; height:6px; border-radius:50%; background:var(--mc-text-muted); animation:aiDot 1.2s infinite ease-in-out; }
    .ai-typing-dots span:nth-child(2) { animation-delay:.15s; }
    .ai-typing-dots span:nth-child(3) { animation-delay:.3s; }
    @@keyframes aiDot { 0%, 60%, 100% { opacity:.3; transform:translateY(0); } 30% { opacity:1; transform:translateY(-3px); } }
    .ai-msg-bubble button:hover { opacity:.85; }
    #aiModal { resize:both; overflow:hidden; direction:ltr; }
    #aiModal.ai-maximized {
        width:calc(100vw - 2rem) !important; height:calc(100vh - 2rem) !important;
        right:1rem !important; bottom:1rem !important;
        border-radius:var(--mc-radius) !important; resize:none !important;
    }
</style>

<script>
    // ===== KI-Assistent =====
    let aiVerlauf = [];
    let aiBesetzt = false;

    function aiOeffnen() {
        const m = document.getElementById('aiModal');
        if (!m) return;
        m.style.display = 'flex';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'none';
        setTimeout(() => document.getElementById('aiInput')?.focus(), 50);
    }

    let aiMax = false;
    let aiPrevStyle = {};

    function aiSchliessen() {
        const m = document.getElementById('aiModal');
        if (m) { m.style.display = 'none'; m.classList.remove('ai-maximized'); }
        aiMax = false;
        const icon = document.getElementById('aiMaxIcon');
        if (icon) icon.className = 'bi bi-arrows-fullscreen';
        const fab = document.getElementById('aiFab');
        if (fab) fab.style.display = 'flex';
    }

    function aiMaximieren() {
        const m = document.getElementById('aiModal');
        const icon = document.getElementById('aiMaxIcon');
        aiMax = !aiMax;
        if (aiMax) {
            aiPrevStyle = { width:m.style.width, height:m.style.height, right:m.style.right, bottom:m.style.bottom, top:m.style.top, left:m.style.left };
            m.classList.add('ai-maximized');
            m.style.top = ''; m.style.left = '';
            icon.className = 'bi bi-fullscreen-exit';
        } else {
            m.classList.remove('ai-maximized');
            Object.assign(m.style, aiPrevStyle);
            icon.className = 'bi bi-arrows-fullscreen';
        }
    }

    // Drag am Header
    (function() {
        var header = document.getElementById('aiHeader');
        var modal = document.getElementById('aiModal');
        if (!header || !modal) return;
        var dragging = false, startX, startY, startRight, startBottom;
        header.addEventListener('mousedown', function(e) {
            if (e.target.closest('button') || aiMax) return;
            dragging = true;
            startX = e.clientX; startY = e.clientY;
            var rect = modal.getBoundingClientRect();
            startRight = window.innerWidth - rect.right;
            startBottom = window.innerHeight - rect.bottom;
            modal.style.transition = 'none';
            e.preventDefault();
        });
        document.addEventListener('mousemove', function(e) {
            if (!dragging) return;
            modal.style.right = Math.max(0, startRight - (e.clientX - startX)) + 'px';
            modal.style.bottom = Math.max(0, startBottom - (e.clientY - startY)) + 'px';
            modal.style.top = 'auto'; modal.style.left = 'auto';
        });
        document.addEventListener('mouseup', function() {
            if (dragging) { dragging = false; modal.style.transition = ''; }
        });
    })();

    function aiPopout() {
        var w = window.open('', 'MerkurHub_KI', 'width=550,height=700,resizable=yes,scrollbars=no');
        if (!w) { alert('Popup wurde blockiert. Bitte erlauben Sie Popups f\u00fcr diese Seite.'); return; }
        var theme = document.documentElement.getAttribute('data-theme') || 'light';
        var petrol = theme === 'dark' ? '#5aabb5' : '#00515A';
        var gold = theme === 'dark' ? '#d4b47a' : '#C8A96E';
        var bg = theme === 'dark' ? '#111118' : '#f3f5f8';
        var surface = theme === 'dark' ? '#1c1c26' : '#ffffff';
        var border = theme === 'dark' ? '#2c2c3a' : '#e4e7eb';
        var text = theme === 'dark' ? '#d0d0dc' : '#4a5568';
        var textDark = theme === 'dark' ? '#e8e8f0' : '#1a202c';
        var textMuted = theme === 'dark' ? '#7a7a8a' : '#8895a7';
        var verlaufJson = JSON.stringify(aiVerlauf);
        w.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>KI-Assistent \u2013 MerkurHub</title>'
            + '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">'
            + '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">'
            + '<style>'
            + '*{box-sizing:border-box;margin:0;padding:0}'
            + 'body{font-family:Inter,system-ui,sans-serif;background:'+bg+';color:'+text+';height:100vh;display:flex;flex-direction:column;}'
            + '.header{padding:.75rem 1rem;background:linear-gradient(135deg,'+petrol+',#2c3e64);color:#fff;display:flex;align-items:center;gap:.5rem;}'
            + '.header i.star{color:'+gold+';font-size:1.15rem}'
            + '.chat{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.5rem;}'
            + '.msg-user{align-self:flex-end;max-width:85%}'
            + '.msg-ast{align-self:flex-start;max-width:90%}'
            + '.bubble{word-wrap:break-word;line-height:1.5;font-size:.9rem;padding:.65rem .8rem;border-radius:10px;}'
            + '.msg-user .bubble{background:'+petrol+';color:#fff;}'
            + '.msg-ast .bubble{background:'+surface+';border:1px solid '+border+';color:'+text+';}'
            + '.bubble strong{color:'+textDark+'}'
            + '.bubble p:last-child{margin-bottom:0}'
            + '.bubble ul,.bubble ol{margin:.25rem 0 .25rem 1.25rem;padding:0}'
            + '.bubble pre{background:rgba(0,0,0,.05);padding:.4rem;border-radius:4px;font-size:.8rem;white-space:pre-wrap}'
            + '.bubble code{background:rgba(0,0,0,.06);padding:.1rem .25rem;border-radius:3px;font-size:.85em}'
            + '.label{font-size:.7rem;color:'+textMuted+';margin-bottom:.2rem;}'
            + '.bar{padding:.75rem;border-top:1px solid '+border+';background:'+surface+';display:flex;gap:.5rem;}'
            + '.bar input{flex:1;padding:.5rem .75rem;border:1px solid '+border+';border-radius:8px;background:'+bg+';color:'+text+';font-size:.9rem;outline:none;font-family:inherit;}'
            + '.bar input:focus{border-color:'+petrol+'}'
            + '.bar button{padding:.5rem 1rem;border:none;border-radius:8px;background:'+petrol+';color:#fff;cursor:pointer;font-size:1rem;}'
            + '.spin{width:18px;height:18px;border:2px solid '+border+';border-top-color:'+petrol+';border-radius:50%;animation:s .7s linear infinite;display:inline-block}'
            + '@@keyframes s{to{transform:rotate(360deg)}}'
            + '</style></head><body>'
            + '<div class="header"><i class="bi bi-stars star"></i><strong>KI-Assistent</strong><span style="font-size:.75rem;opacity:.8;">MerkurHub</span></div>'
            + '<div class="chat" id="chat"></div>'
            + '<div class="bar"><input id="inp" placeholder="Frage eingeben\u2026" autofocus /><button onclick="senden()"><i class="bi bi-send"></i></button></div>'
            + '<script>'
            + 'var verlauf='+verlaufJson+';'
            + 'var besetzt=false;'
            + 'var parentOrigin='+JSON.stringify(window.location.origin)+';'
            + 'document.getElementById("inp").addEventListener("keydown",function(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();senden();}});'
            + 'function md(r){if(!r)return"";var s=r.replace(/&/g,"\\&amp;").replace(/</g,"\\&lt;").replace(/>/g,"\\&gt;");'
            + 's=s.replace(/```(\\w*)\\n?([\\s\\S]*?)```/g,function(m,l,c){return"<pre>"+c.trim()+"</pre>";});'
            + 's=s.replace(/`([^`]+)`/g,"<code>$1</code>");'
            + 's=s.replace(/\\*\\*([^*]+)\\*\\*/g,"<strong>$1</strong>");'
            + 's=s.replace(/(^|[^*])\\*([^*\\n]+)\\*/g,"$1<em>$2</em>");'
            + 's=s.replace(/^###\\s+(.+)$/gm,"<h5 style=\\"font-weight:600;margin:.5rem 0 .25rem\\">$1</h5>");'
            + 's=s.replace(/^##\\s+(.+)$/gm,"<h4 style=\\"font-weight:600;margin:.6rem 0 .3rem\\">$1</h4>");'
            + 's=s.replace(/(^|\\n)((?:\\d+\\.\\s+.+(?:\\n|$))+)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\d+\\.\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ol>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ol>";});'
            + 's=s.replace(/(^|\\n)(\\s*[-*]\\s+.+(?:\\n\\s*[-*]\\s+.+)*)/g,function(m,p,list){var items=list.split("\\n").map(function(l){return l.replace(/^\\s*[-*]\\s+/,"").trim();}).filter(function(x){return x;});return p+"<ul>"+items.map(function(i){return"<li>"+i+"</li>";}).join("")+"</ul>";});'
            + 'return s.split(/\\n{2,}/).map(function(p){p=p.trim();if(!p||/^<(h[1-6]|ul|ol|pre|table|hr)/.test(p))return p;return"<p style=\\"margin:0 0 .4rem\\">"+p.replace(/\\n/g,"<br/>")+"</p>";}).join("");'
            + '}'
            + 'function msg(rolle,text){var c=document.getElementById("chat");var w=document.createElement("div");w.className=rolle==="user"?"msg-user":"msg-ast";var b=document.createElement("div");b.className="bubble";'
            + 'if(rolle==="assistant"){b.innerHTML="<div class=\\"label\\">KI-Assistent</div>"+md(text);}else{b.textContent=text;}'
            + 'w.appendChild(b);c.appendChild(w);c.scrollTop=c.scrollHeight;}'
            + 'if(verlauf.length){verlauf.forEach(function(v){msg(v.rolle==="assistant"?"assistant":"user",v.text);});}else{msg("assistant","Hallo! Ich bin der KI-Assistent. Stelle mir eine Frage.");}'
            + 'async function senden(){var inp=document.getElementById("inp");var frage=inp.value.trim();if(!frage||besetzt)return;besetzt=true;inp.value="";msg("user",frage);'
            + 'var c=document.getElementById("chat");var t=document.createElement("div");t.className="msg-ast";t.innerHTML="<div class=\\"bubble\\"><div class=\\"spin\\"></div> Antwort wird erstellt\\u2026</div>";c.appendChild(t);c.scrollTop=c.scrollHeight;'
            + 'try{var r=await fetch(parentOrigin+"/AiAssistent/Fragen",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({frage:frage,verlauf:verlauf}),credentials:"include"});'
            + 'var d=await r.json();t.remove();if(d.error){msg("assistant","**Fehler:** "+d.error);}else{var a=d.antwort||"(leer)";msg("assistant",a);verlauf.push({rolle:"user",text:frage});verlauf.push({rolle:"assistant",text:a});if(verlauf.length>10)verlauf=verlauf.slice(-10);}'
            + '}catch(e){t.remove();msg("assistant","**Fehler:** Verbindung fehlgeschlagen.");}finally{besetzt=false;inp.focus();}}'
            + '<\/script></body></html>');
        w.document.close();
        aiSchliessen();
    }

    function aiVerlaufLeeren() {
        aiVerlauf = [];
        const cont = document.getElementById('aiNachrichten');
        if (cont) cont.innerHTML = '<div class="ai-msg ai-msg-assistant"><div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div style="font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;">KI-Assistent</div>Verlauf geleert. Stelle eine neue Frage!</div></div>';
    }

    function aiInputKeydown(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            aiSendenAusModal();
        }
    }

    function aiSendenAusModal() {
        const inp = document.getElementById('aiInput');
        if (!inp) return;
        const frage = inp.value.trim();
        if (!frage || aiBesetzt) return;
        inp.value = '';
        aiSenden(frage);
    }

    async function aiSenden(frage) {
        if (aiBesetzt) return;
        aiBesetzt = true;
        const btn = document.getElementById('aiSendBtn');
        if (btn) btn.disabled = true;

        aiNachrichtAnzeigen('user', frage);
        const typingEl = aiTippenZeigen();

        try {
            const resp = await fetch('/AiAssistent/Fragen', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ frage, verlauf: aiVerlauf })
            });
            const data = await resp.json();
            typingEl?.remove();

            if (data.error) {
                aiNachrichtAnzeigen('assistant', '**Fehler:** ' + data.error);
            } else if (data.toolCall) {
                // KI will eine Suche ausloesen -> ans Frontend delegieren
                aiVerlauf.push({ rolle: 'user', text: frage });
                aiToolCallAusfuehren(data.toolCall, frage);
            } else {
                const antwort = data.antwort || '(leere Antwort)';
                aiNachrichtAnzeigen('assistant', antwort);
                aiVerlauf.push({ rolle: 'user', text: frage });
                aiVerlauf.push({ rolle: 'assistant', text: antwort });
                if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
            }
        } catch (err) {
            typingEl?.remove();
            aiNachrichtAnzeigen('assistant', '**Fehler:** Verbindung zum KI-Dienst fehlgeschlagen.');
        } finally {
            aiBesetzt = false;
            if (btn) btn.disabled = false;
            document.getElementById('aiInput')?.focus();
        }
    }

    async function aiToolCallAusfuehren(toolCall, frage) {
        const fn = toolCall.funktion;
        const p = toolCall.parameter;

        if (fn === 'bahn_suchen') {
            const von = p.von || '';
            const nach = p.nach || '';
            const datum = p.datum || '';
            const uhrzeit = p.uhrzeit || '';
            const ersteKlasse = p.erste_klasse || false;

            aiNachrichtAnzeigen('assistant', `Suche Zugverbindungen: **${von}** → **${nach}**` +
                (datum ? ` am ${datum}` : '') + (uhrzeit ? ` um ${uhrzeit}` : '') +
                (ersteKlasse ? ' (1. Klasse)' : '') + '\n\nErgebnisse werden im Suchfenster angezeigt...');

            // Felder im Hub befuellen
            const bahnFrom = document.getElementById('bahnFrom');
            const bahnTo = document.getElementById('bahnTo');
            if (bahnFrom) bahnFrom.value = von;
            if (bahnTo) bahnTo.value = nach;
            if (datum) { const df = document.getElementById('bahnDate'); if (df) df.value = datum; }
            if (uhrzeit) { const tf = document.getElementById('bahnTime'); if (tf) tf.value = uhrzeit; }
            if (ersteKlasse) { const kl = document.getElementById('bahnKlasse'); if (kl) kl.value = '1'; }

            // Suche ausloesen (nutzt die existierende Funktion aus Hub/Index)
            if (typeof bahnSuchen === 'function') {
                await bahnSuchen();
            } else {
                // Fallback: direkte API-Abfrage und Modal oeffnen
                try {
                    const url = `/api/BahnSearch?from=${encodeURIComponent(von)}&to=${encodeURIComponent(nach)}&date=${datum}&time=${uhrzeit}&ersteKlasse=${ersteKlasse}`;
                    const r = await fetch(url);
                    const data = await r.json();
                    let html = `<div style="margin-bottom:.75rem;font-size:.9rem;color:var(--mc-text-muted);"><i class="bi bi-train-front"></i> ${von} → ${nach}</div>`;
                    html += '<table style="width:100%;border-collapse:collapse;font-size:.875rem;"><thead><tr style="border-bottom:2px solid var(--mc-border);text-align:left;"><th style="padding:.5rem;">Abfahrt</th><th>Ankunft</th><th>Dauer</th><th>Umst.</th><th>Züge</th><th>Preis</th></tr></thead><tbody>';
                    data.forEach(c => { html += `<tr style="border-bottom:1px solid var(--mc-border);"><td style="padding:.5rem;font-weight:600;">${c.abfahrt}</td><td>${c.ankunft}</td><td>${c.dauer}</td><td>${c.umstiege}</td><td style="font-size:.8rem;">${c.zuege}</td><td style="color:var(--mc-petrol);font-weight:600;">${c.preis}</td></tr>`; });
                    html += '</tbody></table>';
                    if (typeof showResult === 'function') showResult('Deutsche Bahn — Verbindungen', html);
                } catch {}
            }
        }
        else if (fn === 'mvg_suchen') {
            const von = p.von || '';
            const nach = p.nach || '';
            const uhrzeit = p.uhrzeit || '';

            aiNachrichtAnzeigen('assistant', `Suche MVG-Verbindungen: **${von}** → **${nach}**` +
                (uhrzeit ? ` um ${uhrzeit}` : '') + '\n\nErgebnisse werden im Suchfenster angezeigt...');

            const mvgFrom = document.getElementById('mvgFrom');
            const mvgTo = document.getElementById('mvgTo');
            if (mvgFrom) mvgFrom.value = von;
            if (mvgTo) mvgTo.value = nach;
            if (uhrzeit) { const tf = document.getElementById('mvgTime'); if (tf) tf.value = uhrzeit; }

            if (typeof mvgSuchen === 'function') {
                await mvgSuchen();
            } else {
                try {
                    const r = await fetch(`/api/MvgSearch?from=${encodeURIComponent(von)}&to=${encodeURIComponent(nach)}&time=${uhrzeit}`);
                    const data = await r.json();
                    let html = `<div style="margin-bottom:.75rem;"><i class="bi bi-bus-front"></i> ${von} → ${nach}</div>`;
                    html += '<table style="width:100%;border-collapse:collapse;font-size:.875rem;"><thead><tr style="border-bottom:2px solid var(--mc-border);"><th style="padding:.5rem;">Abfahrt</th><th>Ankunft</th><th>Linie</th><th>Richtung</th><th>Dauer</th></tr></thead><tbody>';
                    data.forEach(c => { html += `<tr style="border-bottom:1px solid var(--mc-border);"><td style="padding:.5rem;font-weight:600;">${c.abfahrt}</td><td>${c.ankunft||''}</td><td>${c.linie}</td><td>${c.richtung}</td><td>${c.dauer}</td></tr>`; });
                    html += '</tbody></table>';
                    if (typeof showResult === 'function') showResult('MVG München — Verbindungen', html);
                } catch {}
            }
        }
        else if (fn === 'verkehr_pruefen') {
            const von = p.von || '';
            const nach = p.nach || '';

            aiNachrichtAnzeigen('assistant', `Prüfe Verkehrslage: **${von}** → **${nach}**\n\nErgebnisse werden im Suchfenster angezeigt...`);

            const tFrom = document.getElementById('trafficFrom');
            const tTo = document.getElementById('trafficTo');
            if (tFrom) tFrom.value = von;
            if (tTo) tTo.value = nach;

            if (typeof verkehrSuchen === 'function') {
                await verkehrSuchen();
            } else {
                try {
                    const r = await fetch(`/api/Traffic?from=${encodeURIComponent(von)}&to=${encodeURIComponent(nach)}`);
                    const d = await r.json();
                    const statusColor = d.status === 'frei' ? 'var(--mc-success)' : d.status === 'stau' ? 'var(--mc-danger)' : 'var(--mc-warning)';
                    let html = `<div style="font-size:1.1rem;font-weight:600;margin-bottom:.5rem;">${d.strecke}</div><div style="color:${statusColor};font-weight:600;text-transform:uppercase;margin-bottom:1rem;">${d.status} — ${d.dauer}</div>`;
                    if (d.staus?.length) { html += '<strong>Staus:</strong><ul>'; d.staus.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
                    if (d.baustellen?.length) { html += '<strong>Baustellen:</strong><ul>'; d.baustellen.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
                    if (d.hinweise?.length) { html += '<strong>Hinweise:</strong><ul>'; d.hinweise.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
                    if (typeof showResult === 'function') showResult('Verkehrslage', html);
                } catch {}
            }
        }
        else {
            aiNachrichtAnzeigen('assistant', 'Diese Funktion ist noch nicht verfügbar.');
        }

        aiVerlauf.push({ rolle: 'assistant', text: `[Suche ausgeführt: ${fn}]` });
        if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
    }

    function aiNachrichtAnzeigen(rolle, text) {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-' + rolle;
        const bubble = document.createElement('div');
        bubble.className = 'ai-msg-bubble';
        if (rolle === 'assistant') {
            bubble.style.background = 'var(--mc-surface)';
            bubble.style.border = '1px solid var(--mc-border)';
            bubble.style.padding = '.75rem';
            bubble.style.borderRadius = 'var(--mc-radius-sm)';
            const label = document.createElement('div');
            label.style.cssText = 'font-size:.75rem; color:var(--mc-text-muted); margin-bottom:.25rem;';
            label.textContent = 'KI-Assistent';
            bubble.appendChild(label);
            const body = document.createElement('div');
            body.innerHTML = aiMarkdown(text);
            bubble.appendChild(body);
        } else {
            bubble.textContent = text;
        }
        wrap.appendChild(bubble);
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
    }

    function aiTippenZeigen() {
        const cont = document.getElementById('aiNachrichten');
        if (!cont) return null;
        const wrap = document.createElement('div');
        wrap.className = 'ai-msg ai-msg-assistant';
        wrap.innerHTML = '<div class="ai-msg-bubble" style="background:var(--mc-surface); border:1px solid var(--mc-border); padding:.75rem; border-radius:var(--mc-radius-sm);"><div class="ai-typing-dots"><span></span><span></span><span></span></div></div>';
        cont.appendChild(wrap);
        cont.scrollTop = cont.scrollHeight;
        return wrap;
    }

    function aiEscapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function aiMarkdown(raw) {
        if (!raw) return '';
        let s = aiEscapeHtml(raw);
        // Code blocks
        s = s.replace(/```([\s\S]*?)```/g, (m, code) => '<pre>' + code.trim() + '</pre>');
        // Inline code
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        // Headings
        s = s.replace(/^###\s+(.+)$/gm, '<h6 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h6>');
        s = s.replace(/^##\s+(.+)$/gm, '<h5 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h5>');
        s = s.replace(/^#\s+(.+)$/gm, '<h4 style="margin:.5rem 0 .25rem; font-weight:600;">$1</h4>');
        // Bold / Italic
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
        // Links [text](url)
        s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        // Dokument-IDs klickbar: #42
        s = s.replace(/(^|[\s(])#(\d{1,6})\b/g, '$1<a href="/Dokumente/Details/$2">#$2</a>');
        // Lists: - or *
        s = s.replace(/(^|\n)(\s*[-*]\s+.+(?:\n\s*[-*]\s+.+)*)/g, (m, p, list) => {
            const items = list.split(/\n/).map(l => l.replace(/^\s*[-*]\s+/, '').trim()).filter(x => x);
            return p + '<ul>' + items.map(i => '<li>' + i + '</li>').join('') + '</ul>';
        });
        // Paragraphs on double newline
        const parts = s.split(/\n{2,}/).map(p => {
            if (/^<(h[1-6]|ul|ol|pre|blockquote)/.test(p.trim())) return p;
            return '<p style="margin:0 0 .4rem;">' + p.replace(/\n/g, '<br/>') + '</p>';
        });
        return parts.join('');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
