async function bahnSuchen() {
    const from = document.getElementById('bahnFrom').value;
    const to = document.getElementById('bahnTo').value;
    const date = document.getElementById('bahnDate').value;
    const time = document.getElementById('bahnTime').value || '00:00';
    if (!from || !to) { alert('Bitte Von und Nach eingeben.'); return; }
    showResult('Deutsche Bahn — Verbindungen', loadingHtml('Verbindungen werden gesucht'));
    const r = await fetch(`/api/BahnSearch?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}&date=${date}&time=${time}`);
    const data = await r.json();
    let html = `<div style="margin-bottom:.75rem;font-size:.9rem;color:var(--mc-text-muted);"><i class="bi bi-train-front"></i> ${from} → ${to} · ${date}</div>`;
    html += '<table style="width:100%;border-collapse:collapse;font-size:.875rem;">';
    html += '<thead><tr style="border-bottom:2px solid var(--mc-border);text-align:left;"><th style="padding:.5rem;">Abfahrt</th><th>Ankunft</th><th>Dauer</th><th>Umst.</th><th>Züge</th><th>Preis</th></tr></thead><tbody>';
    data.forEach(c => {
        html += `<tr style="border-bottom:1px solid var(--mc-border);"><td style="padding:.5rem;font-weight:600;">${c.abfahrt}</td><td>${c.ankunft}</td><td>${c.dauer}</td><td>${c.umstiege}</td><td style="font-size:.8rem;">${c.zuege}</td><td style="color:var(--mc-gold);font-weight:600;">${c.preis}</td></tr>`;
    });
    html += '</tbody></table>';
    html += `<div style="margin-top:1rem;text-align:center;"><a href="https://www.bahn.de" target="_blank" class="btn-mc btn-mc-outline" style="text-decoration:none;">Auf bahn.de buchen <i class="bi bi-box-arrow-up-right"></i></a></div>`;
    showResult('Deutsche Bahn — Verbindungen', html);
}

async function mvgSuchen() {
    const from = document.getElementById('mvgFrom').value;
    const to = document.getElementById('mvgTo').value;
    const time = document.getElementById('mvgTime').value || '';
    if (!from || !to) { alert('Bitte Abfahrt und Ziel eingeben.'); return; }
