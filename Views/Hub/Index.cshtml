async function verkehrSuchen() {
    const from = document.getElementById('trafficFrom').value;
    const to = document.getElementById('trafficTo').value;
    if (!from || !to) { alert('Bitte Start und Ziel eingeben.'); return; }
    showResult('Verkehrslage', loadingHtml('Verkehrsdaten werden abgerufen'));
    const r = await fetch(`/api/Traffic?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`);
    const d = await r.json();
    const statusColor = d.status === 'frei' ? 'var(--mc-success)' : d.status === 'stau' ? 'var(--mc-danger)' : 'var(--mc-warning)';
    const statusIcon = d.status === 'frei' ? 'bi-emoji-smile' : d.status === 'stau' ? 'bi-exclamation-octagon' : 'bi-exclamation-triangle';
    let html = `<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
        <div style="font-size:2.5rem;color:${statusColor};"><i class="bi ${statusIcon}"></i></div>
        <div><div style="font-size:1.1rem;font-weight:600;">${d.strecke}</div>
        <div style="color:${statusColor};font-weight:600;text-transform:uppercase;">${d.status}</div>
        <div style="font-size:.85rem;color:var(--mc-text-muted);">Geschätzte Fahrzeit: ${d.dauer}</div></div></div>`;
    if (d.staus?.length) { html += '<div style="margin-bottom:.5rem;"><strong>Staus:</strong></div><ul style="margin:0 0 .75rem 1.25rem;">'; d.staus.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
    if (d.baustellen?.length) { html += '<div style="margin-bottom:.5rem;"><strong>Baustellen:</strong></div><ul style="margin:0 0 .75rem 1.25rem;">'; d.baustellen.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
    if (d.hinweise?.length) { html += '<div style="margin-bottom:.5rem;"><strong>Hinweise:</strong></div><ul style="margin:0 0 .75rem 1.25rem;">'; d.hinweise.forEach(s => html += `<li>${s}</li>`); html += '</ul>'; }
    showResult('Verkehrslage', html);
}

function loadingHtml(text) {
    return `<div style="display:flex; flex-direction:column; align-items:center; padding:2.5rem 1rem; gap:1rem;">
        <div class="search-spinner"></div>
        <div style="color:var(--mc-text-muted); font-size:.9rem;">${text}...</div>
    </div>`;
}

function showResult(title, html) {
    document.getElementById('resultTitle').textContent = title;
    document.getElementById('resultBody').innerHTML = html;
    document.getElementById('resultModal').classList.add('active');
}

// ═══ Tiles ════════════════════════════════════════════════════════════════════
let tilesFarbe = '#1a1a2e';

function pickColor(el) {
    document.querySelectorAll('.color-pick').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    tilesFarbe = el.dataset.c;
    document.getElementById('tileFarbe').value = tilesFarbe;
}

async function loadTiles() {
    const r = await fetch('/api/Tiles');
    const tiles = await r.json();
    const grid = document.getElementById('tilesGrid');
    const addBtn = grid.querySelector('.mc-tile-add');
    grid.querySelectorAll('.mc-tile:not(.mc-tile-add)').forEach(el => el.remove());
    tiles.forEach(t => {
        const el = document.createElement('a');
        el.className = 'mc-tile';
        el.href = t.url;
        el.target = '_blank';
        el.draggable = true;
        el.dataset.tileId = t.id;
        el.ondragstart = function(e) { tileDragStart(e, t.id); };
        el.ondragover = tileDragOver;
        el.ondragleave = tileDragLeave;
        el.ondragend = tileDragEnd;
        el.ondrop = function(e) { tileDrop(e, t.id); };
        el.innerHTML = `<div class="mc-tile-actions">
            <button onclick="event.preventDefault();event.stopPropagation();tileBearbeiten(${t.id},'${esc(t.titel)}','${esc(t.url)}','${esc(t.icon||'')}','${esc(t.farbe||'#1a1a2e')}')"><i class="bi bi-pencil"></i></button>
            <button onclick="event.preventDefault();event.stopPropagation();tileLoeschen(${t.id})"><i class="bi bi-trash"></i></button>
        </div>
        <div class="mc-tile-icon" style="background:${t.farbe||'linear-gradient(135deg,#1a1a2e,#2c3e64)'};">
            <i class="bi ${t.icon||'bi-globe'}"></i>
        </div>
        <div class="mc-tile-title">${esc(t.titel)}</div>`;
        grid.insertBefore(el, addBtn);
    });
}

function esc(s) { return s ? s.replace(/'/g, "\\'").replace(/"/g, '&quot;') : ''; }

function tileDialog(id, titel, url, icon, farbe) {
    document.getElementById('tileEditId').value = id || '';
    document.getElementById('tileTitel').value = titel || '';
    document.getElementById('tileUrl').value = url || '';
    document.getElementById('tileIcon').value = icon || '';
    tilesFarbe = farbe || '#1a1a2e';
    document.getElementById('tileFarbe').value = tilesFarbe;
    document.querySelectorAll('.color-pick').forEach(b => { b.classList.toggle('active', b.dataset.c === tilesFarbe); });
    document.getElementById('tileModalTitle').textContent = id ? 'Schnellzugriff bearbeiten' : 'Schnellzugriff hinzufügen';
    document.getElementById('tileModal').classList.add('active');
}
function tileModalClose() { document.getElementById('tileModal').classList.remove('active'); }

function tileBearbeiten(id, titel, url, icon, farbe) { tileDialog(id, titel, url, icon, farbe); }

async function tileLoeschen(id) {
    if (!confirm('Schnellzugriff löschen?')) return;
    await fetch('/api/TilesDelete/' + id, { method: 'DELETE' });
    loadTiles();
}

async function tileSpeichern() {
    const id = document.getElementById('tileEditId').value;
    const body = {
        titel: document.getElementById('tileTitel').value,
        url: document.getElementById('tileUrl').value,
        icon: document.getElementById('tileIcon').value,
        farbe: document.getElementById('tileFarbe').value
    };
    if (id) {
        await fetch('/api/TilesUpdate/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    } else {
        await fetch('/api/TilesCreate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    }
    tileModalClose();
    loadTiles();
}
loadTiles();

// ═══ Tile Drag & Drop ═══════════════════════════════════════════════════════
let draggedTile = null;

function tileDragStart(e, id) {
    draggedTile = { el: e.target.closest('.mc-tile'), id: id };
    e.target.closest('.mc-tile').style.opacity = '0.4';
    e.dataTransfer.effectAllowed = 'move';
}

function tileDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    const target = e.target.closest('.mc-tile');
    if (target && target !== draggedTile?.el && !target.classList.contains('mc-tile-add')) {
        const rect = target.getBoundingClientRect();
        const midX = rect.left + rect.width / 2;
        if (e.clientX < midX) {
            target.style.borderLeft = '3px solid var(--mc-gold)';
            target.style.borderRight = '';
        } else {
            target.style.borderRight = '3px solid var(--mc-gold)';
            target.style.borderLeft = '';
        }
    }
}

function tileDragLeave(e) {
    const target = e.target.closest('.mc-tile');
    if (target) { target.style.borderLeft = ''; target.style.borderRight = ''; }
}

function tileDragEnd(e) {
    e.target.closest('.mc-tile').style.opacity = '';
    document.querySelectorAll('.mc-tile').forEach(t => { t.style.borderLeft = ''; t.style.borderRight = ''; });
    draggedTile = null;
}

async function tileDrop(e, targetId) {
    e.preventDefault();
    if (!draggedTile || draggedTile.id === targetId) return;

    const grid = document.getElementById('tilesGrid');
    const tiles = [...grid.querySelectorAll('.mc-tile:not(.mc-tile-add)')];
    const dragIdx = tiles.findIndex(t => t.dataset.tileId == draggedTile.id);
    const dropIdx = tiles.findIndex(t => t.dataset.tileId == targetId);

    if (dragIdx < 0 || dropIdx < 0) return;

    // Reorder in DOM
    const addBtn = grid.querySelector('.mc-tile-add');
    if (dragIdx < dropIdx) {
        grid.insertBefore(tiles[dragIdx], tiles[dropIdx].nextSibling);
    } else {
        grid.insertBefore(tiles[dragIdx], tiles[dropIdx]);
    }

    // Save new order to server
    const newTiles = [...grid.querySelectorAll('.mc-tile:not(.mc-tile-add)')];
    const order = newTiles.map((t, i) => ({ id: parseInt(t.dataset.tileId), sortierung: i }));
    await fetch('/api/TilesReorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(order)
    });
}

