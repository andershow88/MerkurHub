@model List<MerkurHub.Models.Tile>
@{ ViewData["Title"] = "Hub"; }

<!-- ═══════════════════════════════════════════════════════════════════════════
     OBERER BEREICH: Wetter + Mobilität
     ═══════════════════════════════════════════════════════════════════════ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-cloud-sun"></i> Informationen &amp; Mobilität</div>

    <div style="display:grid; grid-template-columns:1fr minmax(280px, 360px); gap:1.25rem; align-items:start;">

        <!-- Mobilität -->
        <div class="mc-mobility-grid">

            <!-- ── Deutsche Bahn ─────────────────────────────────── -->
            <div class="mc-card" style="padding:0; overflow:hidden; border:none; box-shadow:var(--mc-shadow-lg);">
                <div style="background:linear-gradient(135deg,#EC0016,#c4000f); color:#fff; padding:.85rem 1.25rem; display:flex; align-items:center; gap:.75rem;">
                    <div style="width:36px; height:36px; background:rgba(255,255,255,.15); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-train-front-fill" style="font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <strong style="font-size:1.05rem; display:block; line-height:1.2;">Deutsche Bahn</strong>
                        <span style="font-size:.72rem; opacity:.85;">Verbindungen &amp; Fahrplan</span>
                    </div>
                </div>
                <div style="padding:1.25rem; display:flex; flex-direction:column; gap:.75rem;">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:.75rem;">
                        <div style="position:relative;">
                            <div style="display:flex; align-items:center; gap:.4rem; margin-bottom:.3rem;">
                                <span style="background:#EC0016; color:#fff; width:20px; height:20px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:.65rem; font-weight:700;">A</span>
                                <span style="font-size:.78rem; color:var(--mc-text-muted); font-weight:500;">Von</span>
                            </div>
                            <input type="text" class="mc-input" id="bahnFrom" placeholder="Bahnhof / Stadt" autocomplete="off" oninput="dbAutocomplete(this,'bahnFromAc')" onfocus="dbAutocomplete(this,'bahnFromAc')" />
                            <div class="ac-dropdown" id="bahnFromAc"></div>
                        </div>
                        <div style="position:relative;">
                            <div style="display:flex; align-items:center; gap:.4rem; margin-bottom:.3rem;">
                                <span style="background:#EC0016; color:#fff; width:20px; height:20px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:.65rem; font-weight:700;">B</span>
                                <span style="font-size:.78rem; color:var(--mc-text-muted); font-weight:500;">Nach</span>
                            </div>
                            <input type="text" class="mc-input" id="bahnTo" placeholder="Bahnhof / Stadt" autocomplete="off" oninput="dbAutocomplete(this,'bahnToAc')" onfocus="dbAutocomplete(this,'bahnToAc')" />
                            <div class="ac-dropdown" id="bahnToAc"></div>
                        </div>
                    </div>
                    <div style="display:flex; gap:.65rem; align-items:end; flex-wrap:wrap;">
                        <div style="flex:1; min-width:110px;">
                            <span style="font-size:.75rem; color:var(--mc-text-muted); font-weight:500;">Datum</span>
                            <input type="date" class="mc-input" id="bahnDate" />
                        </div>
                        <div style="min-width:95px;">
                            <span style="font-size:.75rem; color:var(--mc-text-muted); font-weight:500;">Uhrzeit</span>
                            <input type="time" class="mc-input" id="bahnTime" />
                        </div>
                        <button onclick="bahnSuchen()" style="padding:.6rem 1.5rem; border:none; border-radius:var(--mc-radius-sm); background:linear-gradient(135deg,#EC0016,#c4000f); color:#fff; font-weight:600; cursor:pointer; font-size:.9rem; white-space:nowrap; box-shadow:0 2px 8px rgba(236,0,22,.25); transition:all .2s;">
                            <i class="bi bi-search"></i> Suchen
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── MVG München ───────────────────────────────────── -->
            <div class="mc-card" style="padding:0; overflow:hidden; border:none; box-shadow:var(--mc-shadow-lg);">
                <div style="background:linear-gradient(135deg,#486EBE,#3a5a9e); color:#fff; padding:.85rem 1.25rem; display:flex; align-items:center; gap:.75rem;">
                    <div style="width:36px; height:36px; background:rgba(255,255,255,.15); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-bus-front-fill" style="font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <strong style="font-size:1.05rem; display:block; line-height:1.2;">MVG München</strong>
                        <span style="font-size:.72rem; opacity:.85;">Verbindungen &amp; Abfahrten</span>
                    </div>
                </div>
                <div style="padding:1.25rem; display:flex; flex-direction:column; gap:.75rem;">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:.75rem;">
                        <div style="position:relative;">
                            <span style="font-size:.78rem; color:var(--mc-text-muted); font-weight:500; margin-bottom:.3rem; display:block;">Abfahrt</span>
                            <input type="text" class="mc-input" id="mvgFrom" placeholder="Haltestelle / Adresse" autocomplete="off" oninput="mvgAutocomplete(this,'mvgFromAc')" onfocus="mvgAutocomplete(this,'mvgFromAc')" />
                            <div class="ac-dropdown" id="mvgFromAc"></div>
                        </div>
                        <div style="position:relative;">
                            <span style="font-size:.78rem; color:var(--mc-text-muted); font-weight:500; margin-bottom:.3rem; display:block;">Ziel</span>
                            <input type="text" class="mc-input" id="mvgTo" placeholder="Haltestelle / Adresse" autocomplete="off" oninput="mvgAutocomplete(this,'mvgToAc')" onfocus="mvgAutocomplete(this,'mvgToAc')" />
                            <div class="ac-dropdown" id="mvgToAc"></div>
                        </div>
                    </div>
                    <div style="display:flex; gap:.65rem; align-items:end;">
                        <div style="min-width:95px;">
                            <span style="font-size:.75rem; color:var(--mc-text-muted); font-weight:500;">Uhrzeit</span>
                            <input type="time" class="mc-input" id="mvgTime" />
                        </div>
                        <button onclick="mvgSuchen()" style="flex:1; padding:.6rem 1rem; border:none; border-radius:var(--mc-radius-sm); background:linear-gradient(135deg,#486EBE,#3a5a9e); color:#fff; font-weight:600; cursor:pointer; font-size:.9rem; box-shadow:0 2px 8px rgba(72,110,190,.25); transition:all .2s;">
                            <i class="bi bi-search"></i> Verbindung suchen
                        </button>
                    </div>
                </div>
            </div>

            <!-- ── Verkehr ───────────────────────────────────────── -->
            <div class="mc-card" style="padding:0; overflow:hidden; border:none; box-shadow:var(--mc-shadow-lg);">
                <div style="background:linear-gradient(135deg,#e6a817,#d49a10); color:#1a1a2e; padding:.85rem 1.25rem; display:flex; align-items:center; gap:.75rem;">
                    <div style="width:36px; height:36px; background:rgba(0,0,0,.1); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                        <i class="bi bi-car-front-fill" style="font-size:1.2rem;"></i>
                    </div>
                    <div>
                        <strong style="font-size:1.05rem; display:block; line-height:1.2;">Verkehrslage</strong>
                        <span style="font-size:.72rem; opacity:.7;">Stau, Baustellen &amp; Autobahn</span>
                    </div>
                </div>
                <div style="padding:1.25rem; display:flex; gap:.65rem; flex-wrap:wrap; align-items:end;">
                    <div style="flex:1; min-width:120px;">
                        <span style="font-size:.75rem; color:var(--mc-text-muted); font-weight:500;">Startort</span>
                        <input type="text" class="mc-input" id="trafficFrom" placeholder="z.B. München" />
                    </div>
                    <div style="flex:1; min-width:120px;">
                        <span style="font-size:.75rem; color:var(--mc-text-muted); font-weight:500;">Zielort</span>
                        <input type="text" class="mc-input" id="trafficTo" placeholder="z.B. Stuttgart" />
                    </div>
                    <button onclick="verkehrSuchen()" style="padding:.6rem 1.25rem; border:none; border-radius:var(--mc-radius-sm); background:linear-gradient(135deg,#e6a817,#d49a10); color:#1a1a2e; font-weight:600; cursor:pointer; font-size:.9rem; box-shadow:0 2px 8px rgba(230,168,23,.25); transition:all .2s;">
                        <i class="bi bi-search"></i> Prüfen
                    </button>
                </div>
            </div>
        </div>

        <!-- Wetter Widget -->
        <div class="mc-card" id="weatherWidget">
            <div class="mc-card-header"><i class="bi bi-cloud-sun-fill"></i> Wetter <span id="weatherLocation" style="font-weight:400; font-size:.8rem; color:var(--mc-text-muted); margin-left:auto;"></span></div>
            <div class="weather-current">
                <div class="weather-icon" id="weatherIcon">--</div>
                <div>
                    <div class="weather-temp" id="weatherTemp">--°</div>
                    <div style="font-size:.8rem; color:var(--mc-text-muted);" id="weatherDesc">Laden...</div>
                </div>
            </div>
            <div class="weather-forecast" id="weatherForecast"></div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     MITTLERER BEREICH: Konfigurierbare Kacheln
     ═══════════════════════════════════════════════════════════════════════ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-bookmark-star"></i> Meine Schnellzugriffe</div>

    <div class="mc-tiles-grid" id="tilesGrid">
        <!-- Tiles werden per JS geladen -->
        <div class="mc-tile mc-tile-add" onclick="tileDialog()">
            <div class="mc-tile-icon" style="background:transparent; border:2px dashed var(--mc-border); color:var(--mc-text-muted);">
                <i class="bi bi-plus-lg"></i>
            </div>
            <div class="mc-tile-title" style="color:var(--mc-text-muted);">Hinzufügen</div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     UNTERER BEREICH: Dashboard mit Kennzahlen
     ═══════════════════════════════════════════════════════════════════════ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-graph-up-arrow"></i> Dashboard &amp; Kennzahlen</div>

    <!-- KPI Karten -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(220px,100%),1fr)); gap:1rem; margin-bottom:1.5rem;">
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Kernkapital</div>
            <div class="mc-kpi-value" style="font-size:1.35rem;">292.052.494,75 €</div>
            <div class="mc-kpi-trend up"><i class="bi bi-arrow-up-short"></i> per letzter Werktag</div>
            <i class="bi bi-bank mc-kpi-icon"></i>
        </div>
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Großkreditobergrenze (25%)</div>
            <div class="mc-kpi-value" style="font-size:1.35rem;">73.013.123,00 €</div>
            <div class="mc-kpi-trend">25 % des Kernkapitals</div>
            <i class="bi bi-shield-check mc-kpi-icon"></i>
        </div>
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Großkreditgrenze (10%)</div>
            <div class="mc-kpi-value" style="font-size:1.35rem;">29.205.249,48 €</div>
            <div class="mc-kpi-trend">10 % des Kernkapitals</div>
            <i class="bi bi-exclamation-triangle mc-kpi-icon"></i>
        </div>
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Assets under Management</div>
            <div class="mc-kpi-value">1,84 Mrd. €</div>
            <div class="mc-kpi-trend up"><i class="bi bi-arrow-up-short"></i> +3,2 % YTD</div>
            <i class="bi bi-pie-chart mc-kpi-icon"></i>
        </div>
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Leasing-Volumen</div>
            <div class="mc-kpi-value">148,3 Mio. €</div>
            <div class="mc-kpi-trend up"><i class="bi bi-arrow-up-short"></i> +12 Anträge MTD</div>
            <i class="bi bi-file-earmark-text mc-kpi-icon"></i>
        </div>
        <div class="mc-kpi-card">
            <div class="mc-kpi-label">Neukunden Q1</div>
            <div class="mc-kpi-value">127</div>
            <div class="mc-kpi-trend up"><i class="bi bi-arrow-up-short"></i> +18 % ggü. Vorjahr</div>
            <i class="bi bi-people mc-kpi-icon"></i>
        </div>
    </div>

    <!-- Charts -->
    <div class="mc-dashboard-grid">
        <div class="mc-chart-card">
            <div class="mc-chart-title"><i class="bi bi-building" style="color:var(--mc-gold);"></i> Bauträgerbereich</div>
            <canvas id="chartBautraeger" height="220"></canvas>
        </div>
        <div class="mc-chart-card">
            <div class="mc-chart-title"><i class="bi bi-file-earmark-bar-graph" style="color:var(--mc-gold);"></i> Leasing — Anträge &amp; Volumen</div>
            <canvas id="chartLeasing" height="220"></canvas>
        </div>
        <div class="mc-chart-card">
            <div class="mc-chart-title"><i class="bi bi-clipboard-data" style="color:var(--mc-gold);"></i> Kreditmeldewesen — Obligo-Verteilung</div>
            <canvas id="chartKredit" height="220"></canvas>
        </div>
        <div class="mc-chart-card">
            <div class="mc-chart-title"><i class="bi bi-person-plus" style="color:var(--mc-gold);"></i> Neukunden-Onboarding &amp; VV</div>
