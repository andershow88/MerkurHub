</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     MODALS
     ═══════════════════════════════════════════════════════════════════════ -->

<!-- Tile Dialog -->
<div class="mc-modal-overlay" id="tileModal">
    <div class="mc-modal">
        <div class="mc-modal-header">
            <span id="tileModalTitle">Schnellzugriff hinzufügen</span>
            <button class="mc-modal-close" onclick="tileModalClose()">&times;</button>
        </div>
        <div class="mc-modal-body">
            <input type="hidden" id="tileEditId" />
            <label class="mc-label">Titel</label>
            <input class="mc-input" id="tileTitel" placeholder="z.B. Confluence" style="margin-bottom:.75rem;" />
            <label class="mc-label">URL</label>
            <input class="mc-input" id="tileUrl" placeholder="https://..." style="margin-bottom:.75rem;" />
            <label class="mc-label">Icon (Bootstrap Icon Name)</label>
            <input class="mc-input" id="tileIcon" placeholder="z.B. bi-globe, bi-journal, bi-gear" style="margin-bottom:.75rem;" />
            <label class="mc-label">Farbe</label>
            <div style="display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1rem;">
                <button class="color-pick" data-c="#1a1a2e" style="background:#1a1a2e;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#c8a96e" style="background:#c8a96e;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#28a745" style="background:#28a745;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#dc3545" style="background:#dc3545;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#17a2b8" style="background:#17a2b8;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#6f42c1" style="background:#6f42c1;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#e6a817" style="background:#e6a817;" onclick="pickColor(this)"></button>
                <button class="color-pick" data-c="#6b6b6b" style="background:#6b6b6b;" onclick="pickColor(this)"></button>
            </div>
            <input type="hidden" id="tileFarbe" value="#1a1a2e" />
            <button class="btn-mc btn-mc-gold" style="width:100%;" onclick="tileSpeichern()">Speichern</button>
        </div>
    </div>
</div>
<style>
.color-pick{width:32px;height:32px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:all .2s;}
.color-pick:hover,.color-pick.active{border-color:var(--mc-gold);transform:scale(1.15);}
.ac-dropdown{position:absolute;top:100%;left:0;right:0;z-index:50;background:var(--mc-surface);border:1px solid var(--mc-border);border-radius:0 0 var(--mc-radius-sm) var(--mc-radius-sm);box-shadow:var(--mc-shadow-lg);max-height:220px;overflow-y:auto;display:none;}
.ac-dropdown.open{display:block;}
.ac-item{padding:.5rem .75rem;cursor:pointer;font-size:.85rem;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid var(--mc-border);}
.ac-item:last-child{border-bottom:none;}
.ac-item:hover{background:rgba(200,169,110,0.1);}
.ac-item .ac-name{font-weight:500;}
.ac-item .ac-badge{font-size:.65rem;padding:1px 5px;border-radius:3px;font-weight:600;color:#fff;}
.search-spinner{width:40px;height:40px;border:3px solid var(--mc-border);border-top-color:var(--mc-gold);border-radius:50%;animation:spin 0.8s linear infinite;}
@@keyframes spin{to{transform:rotate(360deg);}}
</style>

<!-- Ergebnis-Modal -->
<div class="mc-modal-overlay" id="resultModal">
    <div class="mc-modal" style="max-width:700px;">
        <div class="mc-modal-header">
            <span id="resultTitle">Ergebnis</span>
            <button class="mc-modal-close" onclick="document.getElementById('resultModal').classList.remove('active')">&times;</button>
        </div>
        <div class="mc-modal-body" id="resultBody"></div>
    </div>
</div>

@section Scripts {
<script>
// ═══ Autocomplete ═════════════════════════════════════════════════════════════
const acTimers = {};
document.addEventListener('click', function(e) {
    if (!e.target.closest('.ac-dropdown') && !e.target.closest('.mc-input'))
        document.querySelectorAll('.ac-dropdown').forEach(d => d.classList.remove('open'));
});

function dbAutocomplete(input, dropdownId) {
    const key = dropdownId;
    clearTimeout(acTimers[key]);
    const q = input.value.trim();
    const dd = document.getElementById(dropdownId);
    if (q.length < 1) { dd.classList.remove('open'); return; }
    acTimers[key] = setTimeout(async () => {
        dd.innerHTML = '<div class="ac-item" style="justify-content:center; color:var(--mc-text-muted);"><div class="search-spinner" style="width:18px;height:18px;border-width:2px;"></div></div>';
        dd.classList.add('open');
        try {
            const r = await fetch('/api/BahnStationen?q=' + encodeURIComponent(q));
            const data = await r.json();
            if (!data.length) { dd.innerHTML = '<div class="ac-item" style="color:var(--mc-text-muted); justify-content:center;">Keine Ergebnisse</div>'; return; }
            dd.innerHTML = data.map(s =>
                `<div class="ac-item" onmousedown="event.preventDefault();" onclick="acSelect(this,'${input.id}','${dropdownId}')">
                    <i class="bi bi-geo-alt" style="color:#EC0016; flex-shrink:0;"></i>
                    <span class="ac-name">${escH(s.name)}</span>
                </div>`
            ).join('');
        } catch { dd.innerHTML = '<div class="ac-item" style="color:var(--mc-text-muted); justify-content:center;">Fehler beim Laden</div>'; }
    }, 200);
}

function mvgAutocomplete(input, dropdownId) {
    const key = dropdownId;
    clearTimeout(acTimers[key]);
    const q = input.value.trim();
    const dd = document.getElementById(dropdownId);
    if (q.length < 1) { dd.classList.remove('open'); return; }
    acTimers[key] = setTimeout(async () => {
        dd.innerHTML = '<div class="ac-item" style="justify-content:center; color:var(--mc-text-muted);"><div class="search-spinner" style="width:18px;height:18px;border-width:2px;"></div></div>';
        dd.classList.add('open');
        try {
            const r = await fetch('/api/MvgStationen?q=' + encodeURIComponent(q));
            const data = await r.json();
            if (!data.length) { dd.innerHTML = '<div class="ac-item" style="color:var(--mc-text-muted); justify-content:center;">Keine Ergebnisse</div>'; return; }
            dd.innerHTML = data.map(s => {
                const types = (s.types || '').split(',').filter(Boolean);
                const badges = types.map(t => {
                    const col = t === 'UBAHN' ? '#006CB7' : t === 'SBAHN' ? '#408335' : t === 'TRAM' ? '#D4002A' : t === 'BUS' ? '#00586A' : '#486EBE';
                    return `<span class="ac-badge" style="background:${col};">${t.replace('BAHN','')}</span>`;
                }).join(' ');
                const label = s.place ? s.name + ', ' + s.place : s.name;
                return `<div class="ac-item" onmousedown="event.preventDefault();" onclick="acSelect(this,'${input.id}','${dropdownId}')">
                    <i class="bi bi-geo-alt" style="color:#486EBE; flex-shrink:0;"></i>
                    <span class="ac-name">${escH(label)}</span>
                    <span style="margin-left:auto; display:flex; gap:2px; flex-shrink:0;">${badges}</span>
                </div>`;
            }).join('');
        } catch { dd.innerHTML = '<div class="ac-item" style="color:var(--mc-text-muted); justify-content:center;">Fehler beim Laden</div>'; }
    }, 200);
}

function acSelect(item, inputId, ddId) {
    const name = item.querySelector('.ac-name').textContent;
    document.getElementById(inputId).value = name;
    document.getElementById(ddId).classList.remove('open');
}

function escH(s) { return s ? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }

// ═══ Wetter ═══════════════════════════════════════════════════════════════════
const weatherCodes = {0:'bi-sun-fill',1:'bi-cloud-sun',2:'bi-cloud-sun',3:'bi-clouds',45:'bi-cloud-fog',48:'bi-cloud-fog',
    51:'bi-cloud-drizzle',53:'bi-cloud-drizzle',55:'bi-cloud-drizzle',
    61:'bi-cloud-rain',63:'bi-cloud-rain-heavy',65:'bi-cloud-rain-heavy',
    71:'bi-snow',73:'bi-snow',75:'bi-snow2',77:'bi-snow',
    80:'bi-cloud-rain',81:'bi-cloud-rain-heavy',82:'bi-cloud-rain-heavy',
    95:'bi-cloud-lightning-rain',96:'bi-cloud-lightning-rain',99:'bi-cloud-lightning-rain'};
const weatherLabels = {0:'Klar',1:'Leicht bewölkt',2:'Teilweise bewölkt',3:'Bewölkt',45:'Nebel',48:'Nebel',
    51:'Nieselregen',53:'Nieselregen',55:'Nieselregen',61:'Regen',63:'Starker Regen',65:'Starker Regen',
    71:'Leichter Schnee',73:'Schnee',75:'Starker Schnee',80:'Regenschauer',95:'Gewitter'};
const dayNames = ['So','Mo','Di','Mi','Do','Fr','Sa'];

async function loadWeather() {
    let lat = null, lon = null, locationName = null;

    // 1. Browser Geolocation versuchen
    try {
        const pos = await new Promise((resolve, reject) => {
            if (!navigator.geolocation) return reject('no geo');
            navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 5000, maximumAge: 300000 });
        });
        lat = pos.coords.latitude;
        lon = pos.coords.longitude;
    } catch {}

    // 2. Fallback: IP-basierte Geolocation
    if (!lat) {
        try {
            const ipResp = await fetch('https://ipapi.co/json/');
            const ipData = await ipResp.json();
            if (ipData.latitude && ipData.longitude) {
                lat = ipData.latitude;
                lon = ipData.longitude;
                locationName = ipData.city || ipData.region || null;
            }
        } catch {}
    }

    // 3. Fallback: München
    if (!lat) { lat = 48.1371; lon = 11.5754; locationName = 'München (Standard)'; }

    try {
        const r = await fetch(`/api/Weather?lat=${lat}&lon=${lon}`);
        const d = await r.json();
        document.getElementById('weatherTemp').textContent = Math.round(d.current.temperature_2m) + '°C';
        const code = d.current.weather_code;
        document.getElementById('weatherIcon').innerHTML = `<i class="${weatherCodes[code]||'bi-cloud'}"></i>`;
        document.getElementById('weatherDesc').textContent = weatherLabels[code] || 'Unbekannt';

        if (!locationName) {
            try {
                const geo = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json`);
                const gd = await geo.json();
                locationName = gd.address?.city || gd.address?.town || gd.address?.village || '';
            } catch {}
        }
        document.getElementById('weatherLocation').textContent = locationName || '';

        const fc = document.getElementById('weatherForecast');
        fc.innerHTML = '';
        for (let i = 0; i < d.daily.time.length; i++) {
            const dt = new Date(d.daily.time[i]);
            fc.innerHTML += `<div class="weather-day">
                <div>${dayNames[dt.getDay()]}</div>
                <div class="weather-day-icon"><i class="${weatherCodes[d.daily.weather_code[i]]||'bi-cloud'}"></i></div>
                <div class="weather-day-temps"><span class="hi">${Math.round(d.daily.temperature_2m_max[i])}°</span><span class="lo">${Math.round(d.daily.temperature_2m_min[i])}°</span></div>
            </div>`;
        }
    } catch { document.getElementById('weatherDesc').textContent = 'Fehler beim Laden'; }
}
loadWeather();

